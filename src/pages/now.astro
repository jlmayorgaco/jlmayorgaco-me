---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionTitle from '../components/ui/SectionTitle.astro';
import { getCollection, render } from 'astro:content';

const nowCollection = await getCollection('now');
const nowPage = nowCollection[0];
const { Content } = await render(nowPage);
const lastUpdated = nowPage.data.lastUpdated.toLocaleDateString('en-US', { 
  year: 'numeric', 
  month: 'long', 
  day: 'numeric' 
});
---

<BaseLayout title="Now" description="What I'm working on, reading, and thinking about right now">
  <div class="now-container">
    <header class="page-header">
      <div class="header-bar">
        <div class="bar-screws">
          <span class="screw">⚡</span>
          <span class="screw">⚡</span>
        </div>
        <div class="bar-label">NODE_STATUS_ACTIVE</div>
        <div class="bar-leds">
          <span class="led led-green led-pulse"></span>
          <span class="led led-amber"></span>
        </div>
      </div>
      
      <div class="header-content">
        <SectionTitle as="h1">Now</SectionTitle>
        <p class="page-description">
          Current focus, active projects, and what I'm learning. 
          Last updated: <time datetime={nowPage.data.lastUpdated.toISOString()}>{lastUpdated}</time>
        </p>
        <div class="status-badge active">
          <span class="status-dot"></span>
          <span class="status-label">STATUS: ACTIVE</span>
        </div>
      </div>
    </header>

    <article class="now-content">
      <Content />
    </article>
    
    <footer class="now-footer">
      <div class="footer-note">
        <span class="footer-icon">📍</span>
        <span>This page follows the <a href="https://nownownow.com/about" target="_blank" rel="noopener noreferrer">now page</a> convention</span>
      </div>
    </footer>
  </div>
</BaseLayout>

<style>
  .now-container {
    max-width: var(--container-md);
    margin: 0 auto;
    padding: var(--space-lg);
  }
  
  .page-header {
    margin-bottom: var(--space-2xl);
  }
  
  .header-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-sm) var(--space-md);
    background: var(--lab-bg-dark);
    border: 1px solid var(--panel-border);
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
    margin-bottom: -1px;
  }
  
  .bar-screws {
    display: flex;
    gap: var(--space-md);
    color: var(--lab-text-muted);
    font-size: 0.625rem;
  }
  
  .bar-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--accent-cyan);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  
  .bar-leds {
    display: flex;
    gap: var(--space-xs);
  }
  
  .led {
    width: 6px;
    height: 6px;
    border-radius: 50%;
  }
  
  .led-green {
    background: var(--led-green);
    box-shadow: 0 0 4px var(--led-green);
  }
  
  .led-amber {
    background: var(--led-amber);
  }
  
  .led-pulse {
    animation: pulse 2s ease-in-out infinite;
  }
  
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }
  
  .header-content {
    background: var(--lab-bg-panel);
    border: 1px solid var(--panel-border);
    border-top: none;
    border-radius: 0 0 var(--radius-lg) var(--radius-lg);
    padding: var(--space-lg);
  }
  
  .page-description {
    font-size: var(--text-lg);
    color: var(--lab-text-secondary);
    max-width: 600px;
    margin-top: var(--space-md);
    line-height: 1.7;
  }
  
  .page-description time {
    color: var(--accent-cyan);
    font-family: var(--font-mono);
  }
  
  .status-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    margin-top: var(--space-md);
    padding: var(--space-xs) var(--space-md);
    background: var(--lab-bg-dark);
    border: 1px solid var(--panel-border);
    border-radius: var(--radius-sm);
  }
  
  .status-badge.active {
    border-color: var(--accent-green);
  }
  
  .status-badge.active .status-dot {
    background: var(--led-green);
    box-shadow: 0 0 4px var(--led-green);
  }
  
  .status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    animation: blink 2s ease-in-out infinite;
  }
  
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }
  
  .status-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--lab-text-secondary);
    letter-spacing: 0.05em;
  }
  
  /* Content styles */
  .now-content {
    background: var(--lab-bg-panel);
    border: 1px solid var(--panel-border);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
  }
  
  .now-content :global(h2) {
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--accent-cyan);
    margin-top: var(--space-2xl);
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid var(--panel-border);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  
  .now-content :global(h2:first-child) {
    margin-top: 0;
  }
  
  .now-content :global(h3) {
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--lab-text-primary);
    margin-top: var(--space-xl);
    margin-bottom: var(--space-sm);
    border-left: 2px solid var(--accent-cyan);
    padding-left: var(--space-sm);
  }
  
  .now-content :global(h4) {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--lab-text-secondary);
    margin-top: var(--space-lg);
    margin-bottom: var(--space-sm);
  }
  
  .now-content :global(p) {
    color: var(--lab-text-secondary);
    line-height: 1.7;
    margin-bottom: var(--space-md);
  }
  
  .now-content :global(ul),
  .now-content :global(ol) {
    margin-bottom: var(--space-md);
    padding-left: var(--space-lg);
  }
  
  .now-content :global(li) {
    color: var(--lab-text-secondary);
    line-height: 1.6;
    margin-bottom: var(--space-xs);
  }
  
  .now-content :global(ul li)::marker {
    color: var(--accent-cyan);
  }
  
  .now-content :global(strong) {
    color: var(--lab-text-primary);
    font-weight: 600;
  }
  
  .now-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: var(--space-lg) 0;
    background: var(--lab-bg-dark);
    border-radius: var(--radius-md);
    overflow: hidden;
  }
  
  .now-content :global(thead) {
    background: var(--lab-bg-elevated);
  }
  
  .now-content :global(th) {
    padding: var(--space-sm) var(--space-md);
    text-align: left;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--lab-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-bottom: 1px solid var(--panel-border);
  }
  
  .now-content :global(td) {
    padding: var(--space-sm) var(--space-md);
    color: var(--lab-text-primary);
    border-bottom: 1px solid var(--panel-border);
  }
  
  .now-content :global(tr:last-child td) {
    border-bottom: none;
  }
  
  .now-content :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: var(--lab-bg-dark);
    padding: 0.125rem 0.375rem;
    border-radius: var(--radius-sm);
    color: var(--accent-amber);
  }
  
  .now-content :global(hr) {
    border: none;
    border-top: 1px solid var(--panel-border);
    margin: var(--space-xl) 0;
  }
  
  .now-content :global(a) {
    color: var(--accent-cyan);
    text-decoration: none;
    border-bottom: 1px solid var(--accent-cyan-dim);
    transition: border-color 0.2s ease;
  }
  
  .now-content :global(a:hover) {
    border-bottom-color: var(--accent-cyan);
  }
  
  /* Checkbox styling */
  .now-content :global(ul li:has(input[type="checkbox"])) {
    list-style: none;
    padding-left: 0;
    display: flex;
    align-items: flex-start;
    gap: var(--space-sm);
  }
  
  .now-content :global(input[type="checkbox"]) {
    appearance: none;
    width: 16px;
    height: 16px;
    border: 1px solid var(--panel-border);
    border-radius: var(--radius-sm);
    background: var(--lab-bg-dark);
    cursor: pointer;
    flex-shrink: 0;
    margin-top: 2px;
  }
  
  .now-content :global(input[type="checkbox"]:checked) {
    background: var(--accent-cyan);
    border-color: var(--accent-cyan);
  }
  
  .now-content :global(input[type="checkbox"]:checked)::after {
    content: '✓';
    display: block;
    color: var(--lab-bg-dark);
    font-size: 12px;
    text-align: center;
    line-height: 14px;
  }
  
  .now-footer {
    margin-top: var(--space-xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--panel-border);
  }
  
  .footer-note {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--text-sm);
    color: var(--lab-text-muted);
  }
  
  .footer-icon {
    font-size: 1.25rem;
  }
  
  .footer-note a {
    color: var(--accent-cyan);
    text-decoration: none;
    border-bottom: 1px solid var(--accent-cyan-dim);
    transition: border-color 0.2s ease;
  }
  
  .footer-note a:hover {
    border-bottom-color: var(--accent-cyan);
  }
  
  @media (max-width: 768px) {
    .now-container {
      padding: var(--space-md);
    }
    
    .header-content {
      padding: var(--space-md);
    }
    
    .page-description {
      font-size: var(--text-base);
    }
    
    .now-content {
      padding: var(--space-lg);
    }
    
    .now-content :global(table) {
      font-size: var(--text-sm);
    }
    
    .now-content :global(th),
    .now-content :global(td) {
      padding: var(--space-xs) var(--space-sm);
    }
  }
</style>