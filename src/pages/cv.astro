---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/ui/Icon.astro';

const cvVersion = Astro.url.searchParams.get('v') || 'engineering';
---

<BaseLayout title="CV" description="Curriculum Vitae - José Luis Mayorga">
  <div class="cv-page">
    <div class="cv-header-bar">
      <div class="bar-screws">
        <Icon name="screw" size={10} />
        <Icon name="screw" size={10} />
      </div>
      <div class="bar-label">CURRICULUM_VITAE</div>
      <div class="bar-actions">
        <a href="/cv?v=engineering" class={`version-btn ${cvVersion === 'engineering' ? 'active' : ''}`}>Engineering</a>
        <a href="/cv?v=research" class={`version-btn ${cvVersion === 'research' ? 'active' : ''}`}>Research</a>
        <button onclick="window.print()" class="print-btn">
          <Icon name="file" size={14} />
          Download PDF
        </button>
      </div>
    </div>

    <div class="cv-content">
      <header class="cv-intro">
        <div class="cv-identity">
          <h1 class="cv-name">José Luis Mayorga</h1>
          <p class="cv-title">Research Engineer + Full-Stack Developer</p>
          <p class="cv-focus">
            <span class="focus-tag">robotics</span>
            <span class="focus-tag">control systems</span>
            <span class="focus-tag">power systems</span>
            <span class="focus-tag">scientific tooling</span>
          </p>
        </div>
        <div class="cv-contact">
          <div class="contact-item">
            <Icon name="mail" size={12} />
            <span>hello@jlmayorga.co</span>
          </div>
          <div class="contact-item">
            <Icon name="globe" size={12} />
            <span>jlmayorga.co</span>
          </div>
          <div class="contact-item">
            <Icon name="github" size={12} />
            <span>github.com/jlmayorga</span>
          </div>
        </div>
      </header>

      {cvVersion === 'engineering' && (
        <div class="cv-section">
          <h2 class="section-title">
            <span class="section-num">01</span>
            Experience
          </h2>
          
          <div class="timeline">
            <div class="timeline-item">
              <div class="timeline-header">
                <h3>Alert Logic</h3>
                <span class="timeline-period">2021 – Present</span>
              </div>
              <p class="timeline-role">Senior Frontend Developer</p>
              <ul class="timeline-details">
                <li>Architecture improvements for monitoring platforms</li>
                <li>Data visualization systems for security analytics</li>
                <li>UI development for complex enterprise systems</li>
                <li>Performance optimization and code quality</li>
              </ul>
            </div>

            <div class="timeline-item">
              <div class="timeline-header">
                <h3>Vurbis / Freelance</h3>
                <span class="timeline-period">2018 – 2021</span>
              </div>
              <p class="timeline-role">Full-Stack Developer</p>
              <ul class="timeline-details">
                <li>IoT dashboards and real-time systems</li>
                <li>E-commerce platforms and ML projects</li>
                <li>End-to-end full-stack delivery</li>
              </ul>
            </div>
          </div>
        </div>
      )}

      {cvVersion === 'research' && (
        <div class="cv-section">
          <h2 class="section-title">
            <span class="section-num">01</span>
            Research Experience
          </h2>
          
          <div class="timeline">
            <div class="timeline-item">
              <div class="timeline-header">
                <h3>Academic Research</h3>
                <span class="timeline-period">2018 – Present</span>
              </div>
              <p class="timeline-role">Independent Research</p>
              <ul class="timeline-details">
                <li>Distributed control systems for multi-agent robotics</li>
                <li>FPGA-based estimation algorithms (Kalman filters)</li>
                <li>Real-time signal processing for power systems</li>
                <li>Benchmarking frameworks for frequency estimators</li>
              </ul>
            </div>

            <div class="timeline-item">
              <div class="timeline-header">
                <h3>Open Source Research Tools</h3>
                <span class="timeline-period">2020 – Present</span>
              </div>
              <p class="timeline-role">Tool Development</p>
              <ul class="timeline-details">
                <li>OpenFreqBench: benchmarking framework for power system estimators</li>
                <li>FPGA Kalman Filter architectures</li>
                <li>Multi-agent system simulations</li>
              </ul>
            </div>
          </div>
        </div>
      )}

      <div class="cv-section">
        <h2 class="section-title">
          <span class="section-num">02</span>
          Education
        </h2>
        
        <div class="education-grid">
          <div class="edu-card">
            <div class="edu-header">
              <h3>MSc Electronics & Computer Engineering</h3>
              <span class="edu-year">2020</span>
            </div>
            <p class="edu-school">Universidad de los Andes</p>
          </div>
          
          <div class="edu-card">
            <div class="edu-header">
              <h3>MSc Big Data & AI</h3>
              <span class="edu-year">2022</span>
            </div>
            <p class="edu-school">Universidad Isabel I</p>
          </div>
          
          <div class="edu-card">
            <div class="edu-header">
              <h3>BSc Electronic Engineering</h3>
              <span class="edu-year">2018</span>
            </div>
            <p class="edu-school">Universidad de los Andes</p>
          </div>
        </div>
      </div>

      <div class="cv-section">
        <h2 class="section-title">
          <span class="section-num">03</span>
          Skills
        </h2>
        
        <div class="skills-grid">
          <div class="skill-category">
            <h3>Engineering</h3>
            <ul>
              <li>Control Systems</li>
              <li>Robotics</li>
              <li>Power Systems</li>
              <li>FPGA / HDL</li>
              <li>Real-time Systems</li>
            </ul>
          </div>
          
          <div class="skill-category">
            <h3>Software</h3>
            <ul>
              <li>TypeScript / JavaScript</li>
              <li>React / Angular</li>
              <li>Node.js / Python</li>
              <li>Databases / APIs</li>
              <li>Cloud Architecture</li>
            </ul>
          </div>
          
          <div class="skill-category">
            <h3>Research</h3>
            <ul>
              <li>Benchmarking</li>
              <li>Simulation</li>
              <li>Statistical Analysis</li>
              <li>Academic Writing</li>
              <li>Peer Review</li>
            </ul>
          </div>
        </div>
      </div>

      <div class="cv-section">
        <h2 class="section-title">
          <span class="section-num">04</span>
          Languages
        </h2>
        
        <div class="languages-grid">
          <div class="lang-item">
            <span class="lang-name">Spanish</span>
            <span class="lang-level">Native</span>
          </div>
          <div class="lang-item">
            <span class="lang-name">English</span>
            <span class="lang-level">C1 – Professional</span>
          </div>
          <div class="lang-item">
            <span class="lang-name">Chinese</span>
            <span class="lang-level">B1 – Intermediate</span>
          </div>
          <div class="lang-item">
            <span class="lang-name">Japanese</span>
            <span class="lang-level">A2 – Basic</span>
          </div>
        </div>
      </div>

      <div class="cv-section">
        <h2 class="section-title">
          <span class="section-num">05</span>
          What I Look For
        </h2>
        
        <div class="looking-grid">
          <div class="looking-item">
            <Icon name="search" size={16} />
            <span>Research collaborations</span>
          </div>
          <div class="looking-item">
            <Icon name="target" size={16} />
            <span>Technical challenges</span>
          </div>
          <div class="looking-item">
            <Icon name="chip" size={16} />
            <span>Systems engineering problems</span>
          </div>
          <div class="looking-item">
            <Icon name="zap" size={16} />
            <span>Advanced engineering roles</span>
          </div>
        </div>
      </div>

      <div class="cv-section">
        <h2 class="section-title">
          <span class="section-num">06</span>
          Positioning
        </h2>
        
        <div class="positioning-box">
          <p>I build systems that sit between:</p>
          <div class="position-grid">
            <span>theory</span>
            <span class="separator">and</span>
            <span>implementation</span>
            <span>research</span>
            <span class="separator">and</span>
            <span>production</span>
            <span>control</span>
            <span class="separator">and</span>
            <span>software</span>
          </div>
        </div>
      </div>
    </div>

    <div class="cv-footer">
      <div class="footer-screws">
        <Icon name="screw" size={8} />
        <Icon name="screw" size={8} />
      </div>
      <span class="footer-label">END_CV</span>
    </div>
  </div>
</BaseLayout>

<style>
  .cv-page {
    background: var(--lab-bg-panel);
    border: 1px solid var(--panel-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    max-width: 900px;
    margin: 0 auto;
  }

  .cv-header-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-sm) var(--space-md);
    background: var(--lab-bg-dark);
    border-bottom: 1px solid var(--panel-border);
  }

  .bar-screws {
    display: flex;
    gap: var(--space-md);
    color: var(--lab-text-muted);
  }

  .bar-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--accent-cyan);
    letter-spacing: 0.1em;
  }

  .bar-actions {
    display: flex;
    gap: var(--space-sm);
    align-items: center;
  }

  .version-btn {
    padding: 4px 12px;
    font-family: var(--font-mono);
    font-size: 0.625rem;
    color: var(--lab-text-muted);
    text-decoration: none;
    border: 1px solid var(--panel-border);
    border-radius: var(--radius-sm);
    transition: all 0.2s ease;
  }

  .version-btn:hover,
  .version-btn.active {
    color: var(--accent-cyan);
    border-color: var(--accent-cyan);
  }

  .print-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 4px 12px;
    font-family: var(--font-mono);
    font-size: 0.625rem;
    color: var(--lab-bg-base);
    background: var(--accent-cyan);
    border: none;
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .print-btn:hover {
    background: var(--accent-cyan-dim);
  }

  .cv-content {
    padding: var(--space-xl) var(--space-lg);
  }

  .cv-intro {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: var(--space-2xl);
    padding-bottom: var(--space-xl);
    border-bottom: 1px solid var(--panel-border);
  }

  .cv-name {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 700;
    color: var(--lab-text-primary);
    margin: 0 0 var(--space-xs) 0;
  }

  .cv-title {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--accent-cyan);
    margin: 0 0 var(--space-md) 0;
  }

  .cv-focus {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin: 0;
  }

  .focus-tag {
    padding: 2px 8px;
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    color: var(--lab-text-muted);
    background: var(--lab-bg-dark);
    border-radius: var(--radius-sm);
    text-transform: lowercase;
  }

  .cv-contact {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .contact-item {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--lab-text-secondary);
  }

  .cv-section {
    margin-bottom: var(--space-xl);
  }

  .section-title {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--lab-text-primary);
    margin: 0 0 var(--space-lg) 0;
    padding-bottom: var(--space-sm);
    border-bottom: 2px solid var(--accent-cyan);
  }

  .section-num {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--accent-cyan);
  }

  .timeline {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .timeline-item {
    padding-left: var(--space-md);
    border-left: 2px solid var(--panel-border);
  }

  .timeline-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: var(--space-xs);
  }

  .timeline-header h3 {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    color: var(--lab-text-primary);
    margin: 0;
  }

  .timeline-period {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    color: var(--lab-text-muted);
  }

  .timeline-role {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--accent-cyan);
    margin: 0 0 var(--space-sm) 0;
  }

  .timeline-details {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .timeline-details li {
    font-size: 0.875rem;
    color: var(--lab-text-secondary);
    padding: 2px 0;
    padding-left: var(--space-md);
    position: relative;
  }

  .timeline-details li::before {
    content: '>';
    position: absolute;
    left: 0;
    color: var(--accent-cyan-dim);
  }

  .education-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: var(--space-md);
  }

  .edu-card {
    padding: var(--space-md);
    background: var(--lab-bg-elevated);
    border: 1px solid var(--panel-border);
    border-radius: var(--radius-md);
  }

  .edu-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: var(--space-xs);
  }

  .edu-header h3 {
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--lab-text-primary);
    margin: 0;
  }

  .edu-year {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    color: var(--lab-text-muted);
  }

  .edu-school {
    font-size: 0.8125rem;
    color: var(--lab-text-secondary);
    margin: 0;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
  }

  .skill-category h3 {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--accent-cyan);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 var(--space-sm) 0;
  }

  .skill-category ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .skill-category li {
    font-size: 0.8125rem;
    color: var(--lab-text-secondary);
    padding: 2px 0;
    border-bottom: 1px solid var(--panel-border);
  }

  .skill-category li:last-child {
    border-bottom: none;
  }

  .languages-grid {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
  }

  .lang-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: var(--space-sm) var(--space-md);
    background: var(--lab-bg-elevated);
    border: 1px solid var(--panel-border);
    border-radius: var(--radius-md);
    min-width: 120px;
  }

  .lang-name {
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--lab-text-primary);
  }

  .lang-level {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    color: var(--lab-text-muted);
  }

  .looking-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-sm);
  }

  .looking-item {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-sm);
    background: var(--lab-bg-elevated);
    border: 1px solid var(--panel-border);
    border-radius: var(--radius-md);
    font-size: 0.8125rem;
    color: var(--lab-text-secondary);
  }

  .looking-item :global(.icon) {
    color: var(--accent-cyan);
  }

  .positioning-box {
    padding: var(--space-lg);
    background: var(--lab-bg-elevated);
    border: 1px solid var(--panel-border);
    border-radius: var(--radius-md);
    text-align: center;
  }

  .positioning-box > p {
    font-size: 0.875rem;
    color: var(--lab-text-secondary);
    margin: 0 0 var(--space-md) 0;
  }

  .position-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-sm);
  }

  .position-grid span {
    font-family: var(--font-display);
    font-size: 0.9375rem;
    color: var(--lab-text-primary);
  }

  .position-grid .separator {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--accent-cyan);
    font-style: italic;
  }

  .cv-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-xs) var(--space-md);
    background: var(--lab-bg-dark);
    border-top: 1px solid var(--panel-border);
  }

  .footer-screws {
    display: flex;
    gap: var(--space-lg);
    color: var(--lab-text-muted);
    opacity: 0.6;
  }

  .footer-label {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    color: var(--lab-text-muted);
    letter-spacing: 0.15em;
  }

  @media (max-width: 768px) {
    .cv-intro {
      flex-direction: column;
      gap: var(--space-lg);
    }

    .skills-grid {
      grid-template-columns: 1fr;
    }

    .looking-grid {
      grid-template-columns: 1fr;
    }

    .position-grid {
      flex-direction: column;
    }

    .position-grid .separator {
      display: none;
    }
  }

  @media print {
    .cv-page {
      border: none;
      box-shadow: none;
    }

    .cv-header-bar {
      background: white;
      border-bottom: 2px solid black;
    }

    .bar-actions {
      display: none;
    }

    .cv-footer {
      display: none;
    }

    .cv-section {
      page-break-inside: avoid;
    }
  }
</style>
