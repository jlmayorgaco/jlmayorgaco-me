---
import LabLayout from '../../layouts/LabLayout.astro';
import LabShell from '../../components/lab/LabShell';
import DataLabCharts from '../../components/datalab/DataLabCharts';
import DataLabMetrics from '../../components/datalab/DataLabMetrics';
import SectionTitle from '../../components/ui/SectionTitle.astro';
import '../../styles/lab-tokens.css';
import '../../styles/lab-shell.css';
---

<LabLayout title="DataLab | Real-time Analytics">
  <!-- LabShell kept for compatibility but DataLab is primary -->
  <div class="datalab-container">
    <header class="datalab-header">
      <div class="header-bar">
        <div class="bar-screws">
          <span class="screw">⚡</span>
          <span class="screw">⚡</span>
        </div>
        <div class="bar-label">DATALAB_NODE_01</div>
        <div class="bar-leds">
          <span class="led led-green led-pulse"></span>
          <span class="led led-amber"></span>
        </div>
      </div>
      
      <div class="header-content">
        <SectionTitle as="h1">DataLab</SectionTitle>
        <p class="page-description">
          Real-time data visualization dashboard for signal processing, 
          frequency analysis, and system performance monitoring.
        </p>
      </div>
    </header>

    <!-- Key Metrics -->
    <section class="metrics-section">
      <div class="section-label">SYSTEM METRICS</div>
      <DataLabMetrics client:visible />
    </section>

    <!-- Charts Dashboard -->
    <section class="charts-section">
      <div class="section-label">REAL-TIME VISUALIZATION</div>
      <DataLabCharts client:visible />
    </section>
  </div>

  <!-- Keep LabShell below for additional functionality -->
  <LabShell client:load />
</LabLayout>

<style>
  .datalab-container {
    max-width: var(--container-lg);
    margin: 0 auto;
    padding: var(--space-lg);
  }

  .datalab-header {
    margin-bottom: var(--space-2xl);
  }

  .header-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-sm) var(--space-md);
    background: var(--lab-bg-dark);
    border: 1px solid var(--panel-border);
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
    margin-bottom: -1px;
  }

  .bar-screws {
    display: flex;
    gap: var(--space-md);
    color: var(--lab-text-muted);
    font-size: 0.625rem;
  }

  .bar-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--accent-cyan);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .bar-leds {
    display: flex;
    gap: var(--space-xs);
  }

  .led {
    width: 6px;
    height: 6px;
    border-radius: 50%;
  }

  .led-green {
    background: var(--led-green);
    box-shadow: 0 0 4px var(--led-green);
  }

  .led-amber {
    background: var(--led-amber);
  }

  .led-pulse {
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .header-content {
    background: var(--lab-bg-panel);
    border: 1px solid var(--panel-border);
    border-top: none;
    border-radius: 0 0 var(--radius-lg) var(--radius-lg);
    padding: var(--space-lg);
  }

  .page-description {
    font-size: var(--text-lg);
    color: var(--lab-text-secondary);
    max-width: 600px;
    margin-top: var(--space-md);
    line-height: 1.7;
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    color: var(--accent-cyan);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: var(--space-sm);
    padding-left: var(--space-sm);
  }

  .metrics-section {
    margin-bottom: var(--space-xl);
  }

  .charts-section {
    margin-bottom: var(--space-2xl);
  }

  @media (max-width: 768px) {
    .datalab-container {
      padding: var(--space-md);
    }
  }
</style>
