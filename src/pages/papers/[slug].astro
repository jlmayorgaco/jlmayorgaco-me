---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import Icon from '../../components/ui/Icon.astro';

export async function getStaticPaths() {
  const papers = await getCollection('papers');
  return papers.map((paper) => ({
    params: { slug: paper.id },
    props: { paper },
  }));
}

const { paper } = Astro.props;
const { data } = paper;
---

<BaseLayout title={data.title} description={data.abstract}>
  <article class="paper-detail">
    <header class="paper-header">
      <div class="card-header-bar">
        <div class="bar-screws">
          <Icon name="screw" size={10} />
          <Icon name="screw" size={10} />
        </div>
        <div class="bar-label">PAPER_LOG_{data.year}</div>
        <div class="bar-leds">
          <span class="led"></span>
        </div>
      </div>
      
      <div class="paper-content">
        <div class="paper-meta">
          <span class="paper-year">{data.year}</span>
          <span class="paper-venue">{data.venue}</span>
          {data.status !== 'published' && (
            <span class={`paper-status status-${data.status}`}>{data.status}</span>
          )}
        </div>
        
        <h1 class="paper-title">{data.title}</h1>
        
        <p class="paper-authors">
          {data.authors.join(' • ')}
        </p>
      </div>
    </header>

    <section class="paper-section">
      <h2>Abstract</h2>
      <p>{data.abstract}</p>
    </section>

    {data.pdf && (
      <section class="paper-section">
        <h2>PDF</h2>
        <a href={data.pdf} target="_blank" rel="noopener noreferrer" class="paper-link-btn">
          <Icon name="file" size={12} />
          Download PDF
        </a>
      </section>
    )}

    {data.slides && (
      <section class="paper-section">
        <h2>Slides</h2>
        <a href={data.slides} target="_blank" rel="noopener noreferrer" class="paper-link-btn">
          <Icon name="presentation" size={12} />
          View Slides
        </a>
      </section>
    )}

    {data.doi && (
      <section class="paper-section">
        <h2>DOI</h2>
        <a href={data.doi} target="_blank" rel="noopener noreferrer" class="paper-link-btn">
          <Icon name="link" size={12} />
          {data.doi}
        </a>
      </section>
    )}
  </article>
</BaseLayout>

<style>
  .paper-detail {
    max-width: var(--container-md);
    margin: 0 auto;
  }

  .paper-header {
    margin-bottom: var(--space-2xl);
    padding-bottom: var(--space-xl);
    border-bottom: 1px solid var(--panel-border);
    background: var(--lab-bg-panel);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .card-header-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-sm) var(--space-md);
    background: var(--lab-bg-dark);
    border-bottom: 1px solid var(--panel-border);
  }

  .bar-screws {
    display: flex;
    gap: var(--space-md);
    color: var(--lab-text-muted);
  }

  .bar-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--accent-cyan);
    letter-spacing: 0.1em;
  }

  .bar-leds {
    display: flex;
    gap: var(--space-xs);
  }

  .led {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--accent-cyan);
    animation: led-pulse 2s ease-in-out infinite;
  }

  @keyframes led-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .paper-content {
    padding: var(--space-lg);
  }

  .paper-meta {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-md);
  }

  .paper-year {
    font-family: var(--font-mono);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--accent-cyan);
  }

  .paper-venue {
    font-size: 1rem;
    color: var(--lab-text-secondary);
  }

  .paper-status {
    font-size: 0.6875rem;
    text-transform: uppercase;
    padding: 2px 6px;
    border-radius: var(--radius-sm);
  }

   .status-under-review {
     background: rgba(210, 153, 34, 0.2);
     color: var(--led-amber);
   }

  .status-preprint {
    background: var(--lab-bg-elevated);
    color: var(--lab-text-muted);
  }

  .paper-title {
    font-family: var(--font-display);
    font-size: 1.875rem;
    line-height: 1.3;
    margin-bottom: var(--space-md);
    color: var(--lab-text-primary);
  }

  .paper-authors {
    font-size: 1rem;
    color: var(--lab-text-secondary);
    margin-bottom: var(--space-md);
  }

  .paper-section {
    margin-bottom: var(--space-xl);
  }

  .paper-section h2 {
    font-family: var(--font-display);
    font-size: 1.125rem;
    color: var(--lab-text-primary);
    margin-bottom: var(--space-md);
  }

  .paper-section p {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--lab-text-secondary);
  }

  .paper-link-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: var(--space-sm) var(--space-md);
    background: var(--lab-bg-dark);
    border: 1px solid var(--panel-border);
    border-radius: var(--radius-md);
    color: var(--accent-cyan);
    font-family: var(--font-mono);
    font-size: 0.875rem;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .paper-link-btn:hover {
    background: var(--lab-bg-elevated);
    border-color: var(--accent-cyan);
  }
</style>