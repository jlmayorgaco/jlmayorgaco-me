---
import LabLayout from '../layouts/LabLayout.astro';
import LabBoard from '../components/home/LabBoard.astro';
import BlogPreview from '../components/home/BlogPreview.astro';
import HomeVisualSystem from '../components/home/HomeVisualSystem';
import { getCollection } from 'astro:content';
import { getTerminalData } from '../lib/terminal/getTerminalData';

const projects = await getCollection('projects');
const featuredProjects = projects
  .filter(p => p.data.featured)
  .sort((a, b) => b.data.order - a.data.order)
  .slice(0, 2);

const posts = await getCollection('research');
const recentPosts = posts
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const papers = await getCollection('papers');
const tutorials = await getCollection('tutorials');
const portfolio = await getCollection('portfolio');
const terminalData = await getTerminalData();
---

<LabLayout>
  <!-- Hero Section with Clear Value Prop -->
  <header class="hero-header">
    <h1 class="hero-headline">
      Research Engineer
      <span class="headline-sub">Robotics · Distributed Control · FPGA</span>
    </h1>
    <p class="hero-description">
      Building real-time control systems and distributed algorithms for robotics applications.
    </p>
    <div class="hero-cta">
      <Button href="/contact" variant="primary">Get In Touch</Button>
      <Button href="/projects" variant="secondary">See My Work</Button>
    </div>
  </header>
  
  <LabBoard 
    projects={featuredProjects} 
    posts={recentPosts}
    papersCount={papers.length}
    portfolioCount={portfolio.length}
    blogCount={0}
    tutorialsCount={tutorials.length}
    terminalData={terminalData}
  />
  
  <!-- Blog Preview Section -->
  <section class="blog-section">
    <div class="section-container">
      <BlogPreview />
    </div>
  </section>
  
  <HomeVisualSystem client:visible />
</LabLayout>

<style>
  .hero-header {
    text-align: center;
    padding: var(--space-2xl) var(--space-md);
    margin-bottom: var(--space-xl);
  }

  .hero-headline {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    color: var(--lab-text-primary);
    margin: 0 0 var(--space-sm) 0;
    line-height: 1.1;
  }

  .headline-sub {
    display: block;
    font-family: var(--font-mono);
    font-size: clamp(0.875rem, 2vw, 1.125rem);
    color: var(--accent-cyan);
    font-weight: 400;
    margin-top: var(--space-xs);
  }

  .hero-description {
    font-size: var(--text-lg);
    color: var(--lab-text-secondary);
    max-width: 600px;
    margin: var(--space-md) auto var(--space-lg);
    line-height: 1.6;
  }

  .hero-cta {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
    flex-wrap: wrap;
  }

  .cta-primary,
  .cta-secondary {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-sm) var(--space-lg);
    font-family: var(--font-mono);
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: var(--radius-md);
    transition: all 0.2s ease;
  }

  .cta-primary {
    background: var(--accent-cyan);
    color: var(--lab-bg-dark);
    border: none;
  }

  .cta-primary:hover {
    background: var(--accent-cyan-dim);
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(63, 185, 167, 0.3);
  }

  .cta-secondary {
    background: transparent;
    color: var(--lab-text-primary);
    border: 1px solid var(--panel-border);
  }

  .cta-secondary:hover {
    border-color: var(--accent-cyan);
    color: var(--accent-cyan);
    transform: translateY(-2px);
  }

  @media (max-width: 480px) {
    .hero-cta {
      flex-direction: column;
      align-items: stretch;
    }

    .cta-primary,
    .cta-secondary {
      justify-content: center;
      padding: var(--space-md) var(--space-lg);
      min-height: 44px;
    }
  }

  .blog-section {
    padding: var(--space-2xl) 0;
    background: linear-gradient(180deg, var(--lab-bg-base) 0%, var(--lab-bg-dark) 100%);
    border-top: 1px solid var(--panel-border);
  }

  .section-container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--space-lg);
  }

  @media (max-width: 768px) {
    .section-container {
      padding: 0 var(--space-md);
    }
  }
</style>