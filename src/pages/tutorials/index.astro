---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionTitle from '../../components/ui/SectionTitle.astro';
import Icon from '../../components/ui/Icon.astro';
import TutorialsFilter from '../../components/tutorials/TutorialsFilter';
import { getCollection } from 'astro:content';

const tutorials = await getCollection('tutorials');
const publishedTutorials = tutorials.filter(t => !t.data.draft);
const sortedTutorials = publishedTutorials.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const categories = [...new Set(sortedTutorials.map(t => t.data.category))];
const levels = ['beginner', 'intermediate', 'advanced'];

// Serialize tutorials for the React component
const tutorialsData = sortedTutorials.map(t => ({
  id: t.id,
  title: t.data.title,
  description: t.data.description,
  category: t.data.category,
  level: t.data.level,
  duration: t.data.duration,
  tags: t.data.tags || [],
  date: t.data.date.toISOString(),
}));
---

<BaseLayout title="Tutorials" description="Technical tutorials and guides on control systems, robotics, and engineering">
  <div class="tutorials-page">
    <header class="page-header">
      <div class="header-bar">
        <div class="bar-screws">
          <Icon name="screw" size={10} />
          <Icon name="screw" size={10} />
        </div>
        <div class="bar-label">TUTORIALS_NODE</div>
        <div class="bar-leds">
          <span class="led"></span>
        </div>
      </div>
      
      <div class="header-content">
        <SectionTitle as="h1">Tutorials</SectionTitle>
        <p class="page-description">
          Hands-on guides and technical tutorials covering control systems, 
          robotics, embedded systems, and engineering fundamentals.
        </p>
      </div>
    </header>

    <div class="tutorials-stats">
      <div class="stat-panel">
        <div class="stat-icon">
          <Icon name="bookmark" size={20} />
        </div>
        <div class="stat-info">
          <span class="stat-value">{sortedTutorials.length}</span>
          <span class="stat-label">Total Guides</span>
        </div>
      </div>
      <div class="stat-panel">
        <div class="stat-icon">
          <Icon name="tag" size={20} />
        </div>
        <div class="stat-info">
          <span class="stat-value">{categories.length}</span>
          <span class="stat-label">Categories</span>
        </div>
      </div>
      <div class="stat-panel">
        <div class="stat-icon">
          <Icon name="clock" size={20} />
        </div>
        <div class="stat-info">
          <span class="stat-value">{levels.length}</span>
          <span class="stat-label">Difficulty Levels</span>
        </div>
      </div>
    </div>

    <TutorialsFilter client:load tutorials={tutorialsData} />
  </div>
</BaseLayout>

<style>
  .tutorials-page {
    max-width: var(--container-lg);
    margin: 0 auto;
    padding: var(--space-lg) 0;
  }

  .page-header {
    margin-bottom: var(--space-2xl);
  }

  .header-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-sm) var(--space-md);
    background: var(--lab-bg-dark);
    border: 1px solid var(--panel-border);
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
    margin-bottom: -1px;
  }

  .bar-screws {
    display: flex;
    gap: var(--space-md);
    color: var(--lab-text-muted);
  }

  .bar-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--accent-cyan);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .bar-leds {
    display: flex;
    gap: var(--space-xs);
  }

  .led {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--accent-cyan);
    animation: led-pulse 2s ease-in-out infinite;
  }

  @keyframes led-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .header-content {
    background: var(--lab-bg-panel);
    border: 1px solid var(--panel-border);
    border-top: none;
    border-radius: 0 0 var(--radius-lg) var(--radius-lg);
    padding: var(--space-lg);
  }

  .page-description {
    font-size: var(--text-lg);
    color: var(--lab-text-secondary);
    max-width: 600px;
    margin-top: var(--space-md);
    line-height: 1.7;
  }

  .tutorials-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: var(--space-md);
    margin-bottom: var(--space-2xl);
  }

  .stat-panel {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-md);
    background: var(--lab-bg-panel);
    border: 1px solid var(--panel-border);
    border-radius: var(--radius-lg);
  }

  .stat-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: var(--lab-bg-dark);
    border-radius: var(--radius-md);
    color: var(--accent-cyan);
  }

  .stat-info {
    display: flex;
    flex-direction: column;
  }

  .stat-value {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--lab-text-primary);
  }

  .stat-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--lab-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  @media (max-width: 768px) {
    .tutorials-stats {
      grid-template-columns: 1fr;
    }
  }
</style>