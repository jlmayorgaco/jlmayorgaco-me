---
import { getCollection } from 'astro:content';
import LabLayout from '../../layouts/LabLayout.astro';
import { formatDate } from '../../lib/utils';

const posts = await getCollection('blog');
const publishedPosts = posts
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const featuredPosts = publishedPosts.filter((post) => post.data.featured);
const regularPosts = publishedPosts.filter((post) => !post.data.featured);
---

<LabLayout title="Blog | JLMT Lab" description="Technical blog and research notes">
  <div class="blog-container">
    <!-- Header -->
    <header class="blog-header">
      <div class="header-content">
        <span class="label-tag">LAB BLOG</span>
        <h1 class="page-title">Research Notes & Technical Blog</h1>
        <p class="page-description">
          Technical explorations, research insights, and engineering observations from the lab.
        </p>
      </div>
      <div class="header-stats">
        <div class="stat-item">
          <span class="stat-value">{publishedPosts.length}</span>
          <span class="stat-label">Posts</span>
        </div>
      </div>
    </header>

    <!-- Featured Posts -->
    {featuredPosts.length > 0 && (
      <section class="featured-section">
        <h2 class="section-title">
          <span class="section-icon">★</span>
          Featured
        </h2>
        <div class="featured-grid">
          {featuredPosts.map((post) => (
            <article class="featured-card">
              <a href={`/blog/${post.id}`} class="card-link">
                <div class="card-header">
                  <span class="category-badge">{post.data.category}</span>
                  <span class="post-date">{formatDate(post.data.date)}</span>
                </div>
                <h3 class="card-title">{post.data.title}</h3>
                <p class="card-description">{post.data.description}</p>
                <div class="card-footer">
                  <div class="tags">
                    {post.data.tags?.slice(0, 3).map((tag) => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                  <span class="read-more">Read →</span>
                </div>
              </a>
            </article>
          ))}
        </div>
      </section>
    )}

    <!-- All Posts -->
    <section class="posts-section">
      <h2 class="section-title">All Posts</h2>
      <div class="posts-list">
        {regularPosts.map((post) => (
          <article class="post-item">
            <a href={`/blog/${post.id}`} class="item-link">
              <div class="item-meta">
                <span class="category">{post.data.category}</span>
                <span class="date">{formatDate(post.data.date)}</span>
              </div>
              <h3 class="item-title">{post.data.title}</h3>
              <p class="item-description">{post.data.description}</p>
              <div class="item-tags">
                {post.data.tags?.map((tag) => (
                  <span class="item-tag">{tag}</span>
                ))}
              </div>
            </a>
          </article>
        ))}
      </div>
    </section>
  </div>
</LabLayout>

<style>
  .blog-container {
    max-width: var(--container-lg);
    margin: 0 auto;
    padding: var(--space-xl) 0;
  }

  .blog-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: var(--space-2xl);
    padding-bottom: var(--space-xl);
    border-bottom: 1px solid var(--panel-border);
  }

  .header-content {
    flex: 1;
  }

  .label-tag {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.625rem;
    color: var(--accent-cyan);
    letter-spacing: 0.15em;
    margin-bottom: var(--space-sm);
  }

  .page-title {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 700;
    color: var(--lab-text-primary);
    margin-bottom: var(--space-sm);
    letter-spacing: -0.02em;
  }

  .page-description {
    font-size: 1rem;
    color: var(--lab-text-secondary);
    max-width: 600px;
    line-height: 1.6;
  }

  .header-stats {
    display: flex;
    gap: var(--space-lg);
  }

  .stat-item {
    text-align: center;
  }

  .stat-value {
    display: block;
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 700;
    color: var(--accent-cyan);
  }

  .stat-label {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    color: var(--lab-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .featured-section {
    margin-bottom: var(--space-2xl);
  }

  .section-title {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--lab-text-primary);
    margin-bottom: var(--space-lg);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .section-icon {
    color: var(--accent-cyan);
  }

  .featured-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: var(--space-lg);
  }

  .featured-card {
    background: var(--lab-bg-panel);
    border: 1px solid var(--panel-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: all 0.2s ease;
  }

  .featured-card:hover {
    border-color: var(--accent-cyan-dim);
    box-shadow: 0 4px 20px rgba(63, 185, 167, 0.1);
  }

  .card-link {
    display: block;
    padding: var(--space-lg);
    text-decoration: none;
    color: inherit;
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-md);
  }

  .category-badge {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    color: var(--accent-cyan);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 2px 8px;
    background: rgba(63, 185, 167, 0.1);
    border-radius: var(--radius-sm);
  }

  .post-date {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--lab-text-muted);
  }

  .card-title {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--lab-text-primary);
    margin-bottom: var(--space-sm);
    line-height: 1.3;
  }

  .card-description {
    font-size: 0.875rem;
    color: var(--lab-text-secondary);
    line-height: 1.5;
    margin-bottom: var(--space-md);
  }

  .card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .tags {
    display: flex;
    gap: var(--space-xs);
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    color: var(--lab-text-muted);
    padding: 2px 6px;
    background: var(--lab-bg-dark);
    border-radius: var(--radius-sm);
  }

  .read-more {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--accent-cyan);
  }

  .posts-section {
    margin-bottom: var(--space-2xl);
  }

  .posts-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .post-item {
    background: var(--lab-bg-panel);
    border: 1px solid var(--panel-border);
    border-radius: var(--radius-md);
    transition: all 0.2s ease;
  }

  .post-item:hover {
    border-color: var(--accent-cyan-dim);
  }

  .item-link {
    display: block;
    padding: var(--space-md);
    text-decoration: none;
    color: inherit;
  }

  .item-meta {
    display: flex;
    gap: var(--space-md);
    margin-bottom: var(--space-xs);
  }

  .category {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    color: var(--accent-cyan);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .date {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    color: var(--lab-text-muted);
  }

  .item-title {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    color: var(--lab-text-primary);
    margin-bottom: var(--space-xs);
  }

  .item-description {
    font-size: 0.8125rem;
    color: var(--lab-text-secondary);
    line-height: 1.5;
    margin-bottom: var(--space-sm);
  }

  .item-tags {
    display: flex;
    gap: var(--space-xs);
    flex-wrap: wrap;
  }

  .item-tag {
    font-family: var(--font-mono);
    font-size: 0.5rem;
    color: var(--lab-text-muted);
    padding: 1px 6px;
    background: var(--lab-bg-dark);
    border-radius: var(--radius-sm);
  }

  @media (max-width: 768px) {
    .blog-header {
      flex-direction: column;
      gap: var(--space-lg);
    }

    .page-title {
      font-size: 1.5rem;
    }

    .featured-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
