---
import BaseLayout from './BaseLayout.astro';
import PostMeta from '../components/research/PostMeta.astro';
import Icon from '../components/ui/Icon.astro';

interface Props {
  title: string;
  description?: string;
  date: Date;
  tags?: string[];
  category?: string;
  readingTime?: number;
  cover?: string;
}

const { title, description, date, tags, category, readingTime, cover } = Astro.props;
---

<BaseLayout title={title} description={description} type="article">
  <article class="post-layout">
    <div class="post-panel">
      <div class="panel-header">
        <div class="panel-screws">
          <Icon name="screw" size={12} />
          <Icon name="screw" size={12} />
        </div>
        <div class="panel-label">
          <Icon name="doc" size={14} />
          <span>RESEARCH_LOG</span>
        </div>
        <div class="panel-leds">
          <span class="led"></span>
        </div>
      </div>
      <header class="post-header">
        <div class="post-meta-row">
          {category && <span class="label-tag">{category}</span>}
          <span class="post-date">{date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
        </div>
        <h1 class="post-title">{title}</h1>
        {description && <p class="post-description">{description}</p>}
        <div class="post-tags">
          {tags?.map((tag) => (
            <span class="chip">{tag}</span>
          ))}
          {readingTime && <span class="reading-time">{readingTime} min read</span>}
        </div>
      </header>

      {cover && (
        <div class="post-cover">
          <img src={cover} alt={`Cover image for ${title}`} loading="lazy" />
        </div>
      )}

      <div class="post-content prose">
        <slot />
      </div>
    </div>
    <div class="panel-footer">
      <div class="footer-screws">
        <Icon name="screw" size={10} />
        <Icon name="screw" size={10} />
      </div>
      <div class="footer-label">END_LOG</div>
      <div class="footer-stripe"></div>
    </div>
  </article>
</BaseLayout>

<style>
  .post-layout {
    max-width: 800px;
    margin: 0 auto;
  }

  .post-panel {
    background: var(--lab-bg-panel);
    border: 1px solid var(--panel-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-sm) var(--space-md);
    background: linear-gradient(180deg, var(--lab-bg-elevated) 0%, var(--lab-bg-panel) 100%);
    border-bottom: 1px solid var(--panel-border);
  }

  .panel-screws {
    display: flex;
    gap: var(--space-md);
    color: var(--lab-text-muted);
  }

  .panel-label {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--accent-cyan);
    letter-spacing: 0.1em;
  }

  .panel-leds {
    display: flex;
    gap: var(--space-sm);
  }

  .led {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent-cyan);
    animation: led-pulse 2s ease-in-out infinite;
  }

  @keyframes led-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .post-header {
    padding: var(--space-lg);
    border-bottom: 1px solid var(--panel-border);
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      var(--lab-bg-dark) 2px,
      var(--lab-bg-dark) 4px
    );
  }

  .post-meta-row {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-sm);
  }

  .post-date {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--lab-text-muted);
  }

  .post-title {
    font-size: 1.75rem;
    margin-bottom: var(--space-sm);
    line-height: 1.3;
  }

  .post-description {
    font-size: 1rem;
    color: var(--lab-text-secondary);
    margin-bottom: var(--space-md);
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    align-items: center;
  }

  .chip {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    padding: 4px 8px;
    background: var(--lab-bg-dark);
    border: 1px solid var(--panel-border);
    border-radius: var(--radius-sm);
    color: var(--lab-text-secondary);
  }

  .reading-time {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--lab-text-muted);
  }

  .post-cover {
    border-bottom: 1px solid var(--panel-border);
  }

  .post-cover img {
    width: 100%;
    display: block;
  }

  .post-content {
    padding: var(--space-lg);
  }

  .panel-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-xs) var(--space-md);
    background: var(--lab-bg-dark);
    border-top: 1px solid var(--panel-border);
    border-radius: 0 0 var(--radius-lg) var(--radius-lg);
    margin-top: -1px;
  }

  .footer-screws {
    display: flex;
    gap: var(--space-lg);
    color: var(--lab-text-muted);
    opacity: 0.6;
  }

  .footer-label {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    color: var(--lab-text-muted);
    letter-spacing: 0.15em;
  }

  .footer-stripe {
    width: 40px;
    height: 3px;
    background: repeating-linear-gradient(
      90deg,
      var(--panel-border) 0px,
      var(--panel-border) 4px,
      transparent 4px,
      transparent 8px
    );
  }

  @media (max-width: 768px) {
    .post-title {
      font-size: 1.5rem;
    }
  }
</style>