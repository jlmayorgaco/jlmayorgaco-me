---
import '../styles/global.css';
import BaseLayout from './BaseLayout.astro';
import ProjectMetaPanel from '../components/projects/ProjectMetaPanel.astro';

interface Props {
  title: string;
  summary?: string;
  year: number;
  status?: 'published' | 'wip' | 'archived';
  tags?: string[];
  stack?: string[];
  cover?: string;
  links?: {
    demo?: string;
    repo?: string;
    pdf?: string;
  };
}

const { title, summary, year, status = 'published', tags, stack, cover, links } = Astro.props;
---

<BaseLayout title={title} description={summary}>
  <article class="project-layout">
    <header class="project-header">
      <div class="project-status">
        <span class={`status-badge ${status}`}>{status}</span>
        <span class="project-year">{year}</span>
      </div>
      <h1 class="project-title">{title}</h1>
      {summary && <p class="project-summary">{summary}</p>}
    </header>

    {cover && (
      <div class="project-cover">
        <img src={cover} alt="" loading="lazy" />
      </div>
    )}

    <ProjectMetaPanel {tags} {stack} {links} />

    <div class="project-sections">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .project-layout {
    max-width: var(--container-lg);
    margin: 0 auto;
  }

  .project-header {
    margin-bottom: var(--space-2xl);
  }

  .project-status {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-sm);
  }

  .status-badge {
    display: inline-block;
    padding: 2px 8px;
    font-size: var(--text-xs);
    font-family: 'JetBrains Mono', monospace;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: var(--radius-sm);
  }

  .status-badge.published {
    background: var(--color-accent-subtle);
    color: var(--color-accent-primary);
  }

  .status-badge.wip {
    background: rgba(210, 153, 34, 0.2);
    color: var(--color-warning);
  }

  .status-badge.archived {
    background: var(--color-bg-elevated);
    color: var(--color-text-muted);
  }

  .project-year {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    font-family: 'JetBrains Mono', monospace;
  }

  .project-title {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-md);
    line-height: 1.2;
  }

  .project-summary {
    font-size: var(--text-xl);
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .project-cover {
    margin-bottom: var(--space-2xl);
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: var(--border-subtle);
  }

  .project-cover img {
    width: 100%;
    height: auto;
    display: block;
  }

  .project-sections {
    margin-top: var(--space-2xl);
  }

  @media (max-width: 768px) {
    .project-title {
      font-size: var(--text-2xl);
    }
    .project-summary {
      font-size: var(--text-base);
    }
  }
</style>