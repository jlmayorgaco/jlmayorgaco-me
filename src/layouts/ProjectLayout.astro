---
import BaseLayout from './BaseLayout.astro';
import ProjectMetaPanel from '../components/projects/ProjectMetaPanel.astro';
import ProjectRoadmap from '../components/projects/ProjectRoadmap.astro';
import Icon from '../components/ui/Icon.astro';

interface Phase {
  label: string;
  status: 'completed' | 'active' | 'pending' | 'planned';
  date?: string;
}

interface RoadmapData {
  completion: number;
  current_phase: string;
  phases: Phase[];
  what_works: string[];
  limitations: string[];
  next_steps: string[];
}

interface Props {
  title: string;
  summary?: string;
  year: number;
  status?: 'published' | 'wip' | 'archived';
  tags?: string[];
  stack?: string[];
  cover?: string;
  links?: {
    demo?: string;
    repo?: string;
    pdf?: string;
  };
  roadmap?: RoadmapData;
}

const { title, summary, year, status = 'published', tags, stack, cover, links, roadmap } = Astro.props;
---

<BaseLayout title={title} description={summary}>
  <article class="project-panel">
    <div class="panel-header-bar">
      <div class="bar-screws">
        <Icon name="screw" size={10} />
        <Icon name="screw" size={10} />
      </div>
      <div class="bar-label">PROJECT_LOG_{year}</div>
      <div class="bar-leds">
        <span class="led"></span>
      </div>
    </div>
    
    <div class="panel-content">
      <header class="project-header">
        <div class="project-status">
          <span class={`status-badge ${status}`}>{status}</span>
          <span class="project-year">{year}</span>
        </div>
        <h1 class="project-title">{title}</h1>
        {summary && <p class="project-summary">{summary}</p>}
      </header>

      {cover && (
        <div class="project-cover">
          <img src={cover} alt={`Cover image for ${title}`} loading="lazy" />
        </div>
      )}

      {roadmap && <ProjectRoadmap roadmap={roadmap} />}

      <ProjectMetaPanel {tags} {stack} {links} />

      <div class="project-sections">
        <slot />
      </div>
    </div>
    
    <div class="panel-footer">
      <div class="footer-screws">
        <Icon name="screw" size={8} />
        <Icon name="screw" size={8} />
      </div>
      <div class="footer-label">END_LOG</div>
      <div class="footer-stripe"></div>
    </div>
  </article>
</BaseLayout>

<style>
  .project-panel {
    background: var(--lab-bg-panel);
    border: 1px solid var(--panel-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .panel-header-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-sm) var(--space-md);
    background: var(--lab-bg-dark);
    border-bottom: 1px solid var(--panel-border);
  }

  .bar-screws {
    display: flex;
    gap: var(--space-md);
    color: var(--lab-text-muted);
  }

  .bar-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--accent-cyan);
    letter-spacing: 0.1em;
  }

  .bar-leds {
    display: flex;
    gap: var(--space-xs);
  }

  .led {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--accent-cyan);
    animation: led-pulse 2s ease-in-out infinite;
  }

  @keyframes led-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .panel-content {
    padding: var(--space-lg);
  }

  .project-header {
    margin-bottom: var(--space-2xl);
  }

  .project-status {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-sm);
  }

  .status-badge {
    display: inline-block;
    padding: 2px 8px;
    font-size: 0.6875rem;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: var(--radius-sm);
  }

  .status-badge.published {
    background: rgba(6, 182, 212, 0.15);
    color: var(--accent-cyan);
  }

  .status-badge.wip {
    background: rgba(210, 153, 34, 0.2);
    color: var(--led-amber);
  }

  .status-badge.archived {
    background: var(--lab-bg-elevated);
    color: var(--lab-text-muted);
  }

  .project-year {
    font-size: 0.875rem;
    color: var(--lab-text-muted);
    font-family: var(--font-mono);
  }

  .project-title {
    font-family: var(--font-display);
    font-size: 2.25rem;
    margin-bottom: var(--space-md);
    line-height: 1.2;
    color: var(--lab-text-primary);
  }

  .project-summary {
    font-size: 1.125rem;
    color: var(--lab-text-secondary);
    line-height: 1.6;
  }

  .project-cover {
    margin-bottom: var(--space-2xl);
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--panel-border);
  }

  .project-cover img {
    width: 100%;
    height: auto;
    display: block;
  }

  .project-sections {
    margin-top: var(--space-2xl);
  }

  .panel-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-xs) var(--space-md);
    background: var(--lab-bg-dark);
    border-top: 1px solid var(--panel-border);
  }

  .footer-screws {
    display: flex;
    gap: var(--space-lg);
    color: var(--lab-text-muted);
    opacity: 0.6;
  }

  .footer-label {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    color: var(--lab-text-muted);
    letter-spacing: 0.15em;
  }

  .footer-stripe {
    width: 40px;
    height: 3px;
    background: repeating-linear-gradient(
      90deg,
      var(--panel-border) 0px,
      var(--panel-border) 4px,
      transparent 4px,
      transparent 8px
    );
  }

  @media (max-width: 768px) {
    .project-title {
      font-size: 1.75rem;
    }
    .project-summary {
      font-size: 1rem;
    }
  }
</style>