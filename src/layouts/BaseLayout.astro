---
import '../styles/main.scss';
import SiteHead from '../components/shell/SiteHead.astro';
import FooterDock from '../components/shell/FooterDock.astro';
import MobileNav from '../components/shell/MobileNav.astro';
import BottomTabBar from '../components/mobile/BottomTabBar.astro';
import LabHeader from '../components/shell/LabHeader.astro';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
}

const {
  title,
  description,
  canonical,
  image,
  type = 'website',
  publishedTime,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <SiteHead
      title={title}
      description={description}
      canonical={canonical}
      image={image}
      type={type}
      publishedTime={publishedTime}
    />
  </head>
  <body class="base-layout">
    <a href="#main-content" class="skip-link">Skip to content</a>
    <div class="bg-pattern">
      <div class="bg-grid"></div>
      <svg class="bg-cable" viewBox="0 0 100 20" preserveAspectRatio="none">
        <path class="cable-base" d="M0,10 Q25,5 50,10 T100,10" />
        <path class="cable-flow" d="M0,10 Q25,5 50,10 T100,10" />
      </svg>
    </div>
    <LabHeader />
    <MobileNav />
    <main id="main-content" class="base-main">
      <slot />
    </main>
    <FooterDock />
    <BottomTabBar />
  </body>
</html>

