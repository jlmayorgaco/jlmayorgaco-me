---
import '../styles/main.scss';
import SiteHead from '../components/shell/SiteHead.astro';
import TopNav from '../components/shell/TopNav/TopNav.astro';
import FooterDock from '../components/shell/FooterDock.astro';
import MobileNav from '../components/shell/MobileNav.astro';
import BottomTabBar from '../components/mobile/BottomTabBar.astro';
import AmbientDroneLayer from '../components/home/AmbientDroneLayer';
import BackgroundCircuitLayer from '../components/shell/BackgroundCircuitLayer.astro';
import ElectricFieldCursor from '../components/home/ElectricFieldCursor';
import ReactiveCircuitBackground from '../components/home/ReactiveCircuitBackground';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  image?: string;
  type?: 'website' | 'article';
}

const { title, description, canonical, image, type = 'website' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <SiteHead
      title={title}
      description={description}
      canonical={canonical}
      image={image}
      type={type}
    />
  </head>
  <body class="lab-layout">
    <!-- Circuit-style background -->
    <BackgroundCircuitLayer />
    <ReactiveCircuitBackground client:visible />

    <ElectricFieldCursor client:visible>
      <TopNav />
      <MobileNav />

      <main class="lab-main">
        <slot />
      </main>

      <FooterDock />
      <BottomTabBar />
    </ElectricFieldCursor>
    
    <AmbientDroneLayer client:idle />
  </body>
</html>

