---
import type { CollectionEntry } from 'astro:content';
import Badge from '../ui/Badge.astro';

interface Props {
  project: CollectionEntry<'projects'>;
  variant?: 'default' | 'featured' | 'compact';
}

const { project, variant = 'default' } = Astro.props;
const { data } = project;
---

<a href={`/projects/${project.id}`} class:list={['project-card', `card-${variant}`]}>
  {data.cover && (
    <div class="card-cover">
      <img 
        src={data.cover.src} 
        alt={data.title} 
        loading="lazy" 
        width="400"
        height="225"
        decoding="async"
      />
    </div>
  )}
  
  <div class="card-content">
    <div class="card-header">
      <span class="card-year">{data.year}</span>
      <span class={`card-status status-${data.status}`}>{data.status}</span>
    </div>
    
    <h3 class="card-title">{data.title}</h3>
    <p class="card-summary">{data.summary}</p>
    
    {data.stack && variant !== 'compact' && (
      <div class="card-stack">
        {data.stack.slice(0, 4).map((tech) => (
          <span class="stack-item">{tech}</span>
        ))}
      </div>
    )}
    
    {data.tags && (
      <div class="card-tags">
        {data.tags.slice(0, 3).map((tag) => (
          <Badge variant="muted">{tag}</Badge>
        ))}
      </div>
    )}
  </div>
</a>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    background: var(--lab-bg-panel);
    border: 1px solid var(--panel-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    overflow: hidden;
    transition: all 0.2s ease;
  }

  .project-card:hover {
    border-color: var(--accent-cyan);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px -4px rgba(0, 0, 0, 0.4);
  }

  .card-cover {
    aspect-ratio: 16/9;
    overflow: hidden;
    background: var(--lab-bg-elevated);
  }

  .card-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .project-card:hover .card-cover img {
    transform: scale(1.05);
  }

  .card-content {
    padding: var(--space-md);
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-sm);
  }

  .card-year {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--lab-text-muted);
  }

  .card-status {
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 2px 6px;
    border-radius: var(--radius-sm);
  }

  .status-published {
    background: rgba(6, 182, 212, 0.15);
    color: var(--accent-cyan);
  }

   .status-wip {
     background: rgba(210, 153, 34, 0.2);
     color: var(--led-amber);
   }

  .status-archived {
    background: var(--lab-bg-elevated);
    color: var(--lab-text-muted);
  }

  .card-title {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--lab-text-primary);
    margin-bottom: var(--space-sm);
    line-height: 1.3;
  }

  .card-summary {
    font-size: 0.875rem;
    color: var(--lab-text-secondary);
    line-height: 1.5;
    margin-bottom: var(--space-md);
    flex: 1;
  }

  .card-stack {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin-bottom: var(--space-md);
  }

  .stack-item {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--lab-text-muted);
    padding: 2px 6px;
    background: var(--lab-bg-dark);
    border-radius: var(--radius-sm);
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .card-featured {
    grid-column: span 2;
  }

  .card-compact {
    flex-direction: row;
  }

  .card-compact .card-cover {
    width: 120px;
    flex-shrink: 0;
    aspect-ratio: auto;
  }

  .card-compact .card-content {
    padding: var(--space-sm);
  }

  .card-compact .card-title {
    font-size: 1rem;
  }

  .card-compact .card-summary {
    display: none;
  }

  @media (max-width: 768px) {
    .card-featured {
      grid-column: span 1;
    }
  }
</style>