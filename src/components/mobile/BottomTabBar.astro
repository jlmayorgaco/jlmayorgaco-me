---
import { NAV_ITEMS, SITE_TITLE } from '../../lib/config';
import Icon from '../ui/Icon.astro';

const currentPath = Astro.url.pathname;
---

<nav class="tab-bar">
  <ul class="tab-list">
    {NAV_ITEMS.slice(0, 5).map((item) => (
      <li>
        <a
          href={item.href}
          class:list={['tab-item', { active: currentPath.startsWith(item.href) }]}
        >
          <span class="tab-icon">
            <Icon name={getIcon(item.href)} size={16} />
          </span>
          <span class="tab-label">{item.label}</span>
        </a>
      </li>
    ))}
  </ul>
</nav>

<script>
  function getIcon(href: string): keyof typeof import('../ui/Icon.astro')['icons'] {
    if (href === '/') return 'chip';
    if (href === '/projects') return 'projects';
    if (href === '/research') return 'research';
    if (href === '/papers') return 'papers';
    if (href === '/about') return 'about';
    if (href === '/contact') return 'contact';
    return 'chip';
  }
</script>

<style>
  .tab-bar {
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: var(--lab-bg-panel);
    border-top: 1px solid var(--panel-border);
    padding: var(--space-sm);
    z-index: var(--z-sticky);
  }

  @media (max-width: 640px) {
    .tab-bar {
      display: block;
    }
  }

  .tab-list {
    display: flex;
    justify-content: space-around;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .tab-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xs);
    padding: var(--space-xs);
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition: all 0.2s ease;
    position: relative;
    overflow: hidden;
  }

  .tab-item::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--accent-cyan);
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .tab-item.active::before {
    opacity: 1;
  }

  .tab-item.active {
    color: var(--accent-cyan);
  }

  .tab-item:not(.active) {
    color: var(--lab-text-muted);
  }

  .tab-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
  }

  .tab-icon Icon {
    color: currentColor;
  }

  .tab-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
  }
</style>