---
import { NAV_ITEMS } from '../../lib/config';
import Icon from '../ui/Icon.astro';

const currentPath = Astro.url.pathname;

const mobileItems = NAV_ITEMS;

function getIcon(href: string) {
  if (href === '/') return 'chip';
  if (href === '/projects') return 'projects';
  if (href === '/research') return 'research';
  if (href === '/datalab') return 'chip';
  if (href === '/blog') return 'document';
  if (href === '/about') return 'chip';
  return 'chip';
}
---

<nav class="tab-bar" aria-label="Mobile navigation">
  <ul class="tab-list">
    {mobileItems.map((item) => (
      <li>
        <a
          href={item.href}
          class:list={['tab-item', { active: currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href)) }]}
          aria-current={currentPath === item.href ? 'page' : undefined}
        >
          <span class="tab-icon" aria-hidden="true">
            <Icon name={getIcon(item.href)} size={16} />
          </span>
          <span class="tab-label">{item.label}</span>
        </a>
      </li>
    ))}
  </ul>
</nav>

