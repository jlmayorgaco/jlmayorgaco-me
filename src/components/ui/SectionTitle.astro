---
interface Props {
  as?: 'h1' | 'h2' | 'h3' | 'h4' | 'h5' | 'h6';
  subtitle?: string;
  align?: 'left' | 'center';
}

const { as: Tag = 'h2', subtitle, align = 'left' } = Astro.props;
---

<Tag class:list={['section-title', `align-${align}`]}>
  <div class="title-wrapper">
    <div class="title-label">LAB_SECTION</div>
    <div class="title-content"><slot /></div>
  </div>
</Tag>

{subtitle && <p class="section-subtitle">{subtitle}</p>}

<style>
  .section-title {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--lab-text-primary);
    line-height: 1.3;
    position: relative;
  }

  .title-wrapper {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .title-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    background: var(--lab-bg-dark);
    color: var(--accent-cyan);
    padding: 2px 6px;
    border: 1px solid var(--panel-border);
    border-radius: var(--radius-sm);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .title-content {
    font-size: 1.5rem;
  }

  .align-left {
    text-align: left;
  }

  .align-center {
    text-align: center;
    justify-content: center;
  }

  .section-subtitle {
    margin-top: var(--space-sm);
    font-size: 0.875rem;
    color: var(--lab-text-secondary);
    font-weight: 400;
    font-family: var(--font-mono);
  }
</style>