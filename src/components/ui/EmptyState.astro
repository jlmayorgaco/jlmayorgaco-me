---
interface Props {
  title?: string;
}

const { title = 'No content found' } = Astro.props;
---

<div class="empty-panel">
  <div class="panel-header">
    <div class="header-left">
      <Icon name="alert-circle" size={16} />
      <span>SYSTEM_ALERT</span>
    </div>
    <div class="header-right">
      <span class="led led-amber"></span>
    </div>
  </div>
  
  <div class="panel-content">
    <div class="empty-icon">
      <Icon name="circle" size={32} />
    </div>
    <p class="empty-title">{title}</p>
    <div class="empty-description">
      <slot />
    </div>
  </div>
  
  <div class="panel-footer">
    <div class="footer-screws">
      <Icon name="screw" size={8} />
      <Icon name="screw" size={8} />
    </div>
    <div class="footer-label">END_REPORT</div>
  </div>
</div>

<style>
  .empty-panel {
    background: var(--lab-bg-panel);
    border: 1px solid var(--panel-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    text-align: center;
  }

  .panel-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-sm) var(--space-md);
    background: var(--lab-bg-dark);
    border-bottom: 1px solid var(--panel-border);
  }

  .header-left {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .header-left Icon {
    color: var(--accent-amber);
  }

  .header-left span {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--accent-amber);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .led {
    width: 6px;
    height: 6px;
    border-radius: 50%;
  }

  .led-amber {
    background: var(--led-amber);
    box-shadow: 0 0 4px var(--led-amber);
  }

  .panel-content {
    padding: var(--space-lg) var(--space-xl);
  }

  .empty-icon {
    margin-bottom: var(--space-md);
  }

  .empty-icon Icon {
    color: var(--lab-text-muted);
    opacity: 0.6;
  }

  .empty-title {
    font-family: var(--font-display);
    font-size: 1.125rem;
    color: var(--lab-text-secondary);
    margin-bottom: var(--space-sm);
  }

  .empty-description {
    font-size: 0.875rem;
    color: var(--lab-text-muted);
    max-width: 400px;
    margin: 0 auto var(--space-lg);
    line-height: 1.6;
  }

  .panel-footer {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: var(--space-sm);
    background: var(--lab-bg-dark);
    border-top: 1px solid var(--panel-border);
  }

  .footer-screws {
    display: flex;
    gap: var(--space-md);
    color: var(--lab-text-muted);
    opacity: 0.6;
  }

  .footer-label {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    color: var(--lab-text-muted);
    letter-spacing: 0.15em;
  }
</style>