---
interface Props {
  variant?: 'default' | 'accent' | 'muted';
  href?: string;
}

const { variant = 'default', href } = Astro.props;
---

{href ? (
  <a href={href} class:list={['badge', `badge-${variant}`]}>
    <slot />
  </a>
) : (
  <span class:list={['badge', `badge-${variant}`]}>
    <slot />
  </span>
)}

<style>
  .badge {
    display: inline-flex;
    align-items: center;
    padding: 2px 8px;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: var(--radius-sm);
    white-space: nowrap;
    border: 1px solid var(--panel-border);
    transition: all 0.2s ease;
  }

  .badge-default {
    background: var(--lab-bg-dark);
    color: var(--lab-text-secondary);
  }

  .badge-default:hover {
    background: var(--lab-bg-elevated);
    color: var(--lab-text-secondary);
  }

  .badge-accent {
    background: var(--lab-bg-dark);
    color: var(--accent-cyan);
  }

  .badge-accent:hover {
    background: var(--accent-cyan);
    color: var(--lab-bg-dark);
  }

  .badge-muted {
    background: var(--lab-bg-panel);
    color: var(--lab-text-muted);
  }

  .badge-muted:hover {
    background: var(--lab-bg-elevated);
    color: var(--lab-text-muted);
  }
</style>