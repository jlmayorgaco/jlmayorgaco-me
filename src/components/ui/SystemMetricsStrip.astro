---
/**
 * SystemMetricsStrip.astro
 * Animated system metrics display for main monitor
 * Shows simulated CPU/MEM/NET-style indicators
 */
---

<div class="system-metrics" aria-hidden="true">
  <div class="metric-item">
    <div class="metric-header">
      <span class="metric-label">SYS</span>
      <span class="metric-led metric-led-active"></span>
    </div>
    <div class="metric-bar-container">
      <div class="metric-bar metric-bar-sys" style="--bar-fill: 68%"></div>
    </div>
    <span class="metric-value">68%</span>
  </div>

  <div class="metric-divider"></div>

  <div class="metric-item">
    <div class="metric-header">
      <span class="metric-label">MEM</span>
      <span class="metric-led metric-led-active"></span>
    </div>
    <div class="metric-bar-container">
      <div class="metric-bar metric-bar-mem" style="--bar-fill: 54%"></div>
    </div>
    <span class="metric-value">54%</span>
  </div>

  <div class="metric-divider"></div>

  <div class="metric-item">
    <div class="metric-header">
      <span class="metric-label">NET</span>
      <span class="metric-led metric-led-blink"></span>
    </div>
    <div class="metric-bar-container">
      <div class="metric-bar metric-bar-net" style="--bar-fill: 82%"></div>
    </div>
    <span class="metric-value">LINK</span>
  </div>
</div>

<style>
  .system-metrics {
    display: flex;
    align-items: stretch;
    gap: var(--space-sm);
    padding: var(--space-xs) var(--space-sm);
    background: var(--lab-bg-dark);
    border-top: 1px solid var(--screen-border);
  }

  .metric-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    flex: 1;
    min-width: 60px;
  }

  .metric-header {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .metric-label {
    font-family: var(--font-mono);
    font-size: 0.5rem;
    color: var(--lab-text-muted);
    letter-spacing: 0.05em;
  }

  .metric-led {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--led-green);
  }

  .metric-led-active {
    background: var(--led-green);
    box-shadow: 0 0 4px var(--led-green);
    animation: led-breathe 2s ease-in-out infinite;
  }

  .metric-led-blink {
    background: var(--led-amber);
    animation: led-blink 1s step-end infinite;
  }

  @keyframes led-breathe {
    0%, 100% { opacity: 0.6; box-shadow: 0 0 2px var(--led-green); }
    50% { opacity: 1; box-shadow: 0 0 6px var(--led-green); }
  }

  @keyframes led-blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.2; }
  }

  .metric-bar-container {
    width: 100%;
    height: 3px;
    background: var(--screen-bg);
    border-radius: 2px;
    overflow: hidden;
  }

  .metric-bar {
    height: 100%;
    width: var(--bar-fill);
    border-radius: 2px;
    animation: bar-pulse 3s ease-in-out infinite;
  }

  .metric-bar-sys {
    background: linear-gradient(90deg, var(--led-green), var(--accent-cyan));
    animation-delay: 0s;
  }

  .metric-bar-mem {
    background: linear-gradient(90deg, var(--accent-copper), var(--accent-gold));
    animation-delay: 0.5s;
  }

  .metric-bar-net {
    background: linear-gradient(90deg, var(--led-amber), var(--led-green));
    animation-delay: 1s;
  }

  @keyframes bar-pulse {
    0%, 100% {
      opacity: 0.8;
      filter: brightness(1);
    }
    50% {
      opacity: 1;
      filter: brightness(1.2);
    }
  }

  .metric-value {
    font-family: var(--font-mono);
    font-size: 0.4375rem;
    color: var(--accent-cyan);
    letter-spacing: 0.05em;
  }

  .metric-divider {
    width: 1px;
    background: var(--screen-border);
    margin: 2px 0;
  }

  @media (max-width: 768px) {
    .system-metrics {
      gap: var(--space-xs);
      padding: var(--space-xs);
    }

    .metric-item {
      min-width: 50px;
    }

    .metric-label {
      font-size: 0.4375rem;
    }

    .metric-value {
      font-size: 0.375rem;
    }
  }
</style>