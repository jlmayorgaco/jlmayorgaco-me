---
import { SITE_TITLE, SITE_DESCRIPTION, SITE_URL, GA_MEASUREMENT_ID } from '../../lib/config';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  author?: string;
}

const {
  title,
  description = SITE_DESCRIPTION,
  canonical,
  image,
  type = 'website',
  publishedTime,
  author,
} = Astro.props;

const pageTitle = title ? `${title} | ${SITE_TITLE}` : SITE_TITLE;
const canonicalUrl = canonical ? canonical : Astro.url.href;
const ogImage = image ? new URL(image, SITE_URL).href : undefined;

const schemaOrg = type === 'article' ? {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "url": canonicalUrl,
  "datePublished": publishedTime,
  "author": author ? { "@type": "Person", "name": author } : undefined,
} : {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Jorge Luis Mayorga Taborda",
  "url": SITE_URL,
  "jobTitle": "Research Engineer",
  "description": SITE_DESCRIPTION,
  "sameAs": [
    "https://github.com/jlmayorga",
    "https://linkedin.com/in/jlmayorga",
    "https://twitter.com/jlmayorga"
  ]
};
---

<!-- Resource hints for performance -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

<!-- Security headers (meta equivalent for static sites) -->
<meta http-equiv="X-Frame-Options" content="DENY" />
<meta http-equiv="X-Content-Type-Options" content="nosniff" />
<meta http-equiv="Referrer-Policy" content="strict-origin-when-cross-origin" />

<title>{pageTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />

<!-- Robots -->
<meta name="robots" content="index, follow" />

<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:type" content={type} />
{ogImage && <meta property="og:image" content={ogImage} />}

{publishedTime && <meta property="article:published_time" content={publishedTime} />}
{author && <meta property="article:author" content={author} />}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={description} />
{ogImage && <meta name="twitter:image" content={ogImage} />}

<meta name="theme-color" content="#0d1319" />
<meta name="generator" content={Astro.generator} />

<!-- Language -->
<link rel="alternate" hreflang="en" href={canonicalUrl} />
<link rel="alternate" hreflang="x-default" href={canonicalUrl} />

<!-- Keywords for SEO -->
<meta name="keywords" content="control systems, robotics, FPGA, embedded systems, distributed control, research engineer, power electronics, signal processing" />

<script type="application/ld+json" set:html={JSON.stringify(schemaOrg)} />

{GA_MEASUREMENT_ID && (
  <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_MEASUREMENT_ID}`}></script>
  <script is:inline define:vars={{ GA_MEASUREMENT_ID }}>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', GA_MEASUREMENT_ID);
  </script>
)}