---
import { SITE_TITLE, SITE_DESCRIPTION, SITE_URL } from '../../lib/config';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
}

const {
  title,
  description = SITE_DESCRIPTION,
  canonical,
  image,
  type = 'website',
  publishedTime,
} = Astro.props;

const pageTitle = title ? `${title} | ${SITE_TITLE}` : SITE_TITLE;
const canonicalUrl = canonical ? canonical : Astro.url.href;
const ogImage = image ? new URL(image, SITE_URL).href : undefined;
---

<title>{pageTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />

<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:type" content={type} />
{ogImage && <meta property="og:image" content={ogImage} />}

{publishedTime && <meta property="article:published_time" content={publishedTime} />}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={description} />
{ogImage && <meta name="twitter:image" content={ogImage} />}

<meta name="theme-color" content="#0d1319" />
<meta name="generator" content={Astro.generator} />