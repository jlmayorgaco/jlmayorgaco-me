---
import { SOCIAL_LINKS } from '../../lib/config';
---

<footer class="lab-footer">
  <div class="footer-content">
    <!-- Left: Terminal style -->
    <div class="footer-terminal">
      <span class="terminal-prompt">$</span>
      <span class="terminal-text">echo "Stay curious"</span>
    </div>

    <!-- Center: Branding -->
    <div class="footer-brand">
      <span class="brand-marker">◈</span>
      <span class="brand-text">JLMT LAB</span>
      <span class="brand-year">© {new Date().getFullYear()}</span>
    </div>

    <!-- Right: Social -->
    <div class="footer-social">
      {SOCIAL_LINKS.map((link) => (
        <a href={link.href} target="_blank" rel="noopener noreferrer" class="social-link">
          {link.label}
        </a>
      ))}
    </div>
  </div>
</footer>

<style>
  .lab-footer {
    background: var(--lab-bg-elevated);
    border-top: 2px solid var(--panel-frame);
    padding: var(--space-sm) var(--space-md);
    margin-top: var(--space-xl);
  }

  .footer-content {
    max-width: var(--container-max);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-md);
  }

  /* Terminal style left */
  .footer-terminal {
    display: none;
    align-items: center;
    gap: var(--space-sm);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--lab-text-muted);
  }

  @media (min-width: 640px) {
    .footer-terminal {
      display: flex;
    }
  }

  .terminal-prompt {
    color: var(--accent-cyan);
  }

  .terminal-text {
    opacity: 0.7;
  }

  /* Center branding */
  .footer-brand {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .brand-marker {
    font-size: 0.875rem;
    color: var(--accent-cyan);
  }

  .brand-text {
    font-family: var(--font-display);
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--lab-text-primary);
  }

  .brand-year {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--lab-text-muted);
    padding-left: var(--space-sm);
    border-left: 1px solid var(--panel-border);
  }

  /* Social links */
  .footer-social {
    display: flex;
    gap: var(--space-md);
  }

  .social-link {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--lab-text-secondary);
    text-decoration: none;
    transition: color 150ms ease;
  }

  .social-link:hover {
    color: var(--accent-cyan);
  }

  /* Mobile */
  @media (max-width: 640px) {
    .footer-content {
      flex-direction: column;
      text-align: center;
    }

    .footer-brand {
      flex-direction: column;
      gap: var(--space-xs);
    }

    .brand-year {
      border: none;
      padding: 0;
    }
  }
</style>