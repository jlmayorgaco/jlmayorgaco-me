---
import type { CollectionEntry } from 'astro:content';
import PostCard from '../research/PostCard.astro';
import Icon from '../ui/Icon.astro';

interface Props {
  posts: CollectionEntry<'research'>[];
}

const { posts } = Astro.props;
---

<section class="research-preview">
  <header class="section-header">
    <div class="header-bar">
      <div class="bar-screws">
        <Icon name="screw" size={10} />
        <Icon name="screw" size={10} />
      </div>
      <div class="bar-label">RESEARCH_NODE</div>
      <div class="bar-leds">
        <span class="led"></span>
      </div>
    </div>
    <div class="header-content">
      <h2 class="section-title">Recent Research</h2>
      <a href="/research" class="view-all">
        <Icon name="arrow-right" size={12} />
        View all
      </a>
    </div>
  </header>

  <div class="posts-list">
    {posts.map((post) => (
      <PostCard post={post} variant="compact" />
    ))}
  </div>
</section>

<style>
  .research-preview {
    margin-top: var(--space-3xl);
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-xl);
  }

  .header-bar {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    background: var(--lab-bg-dark);
    padding: var(--space-sm) var(--space-md);
    border-radius: var(--radius-md);
    border: 1px solid var(--panel-border);
  }

  .bar-screws {
    display: flex;
    gap: var(--space-md);
    color: var(--lab-text-muted);
  }

  .bar-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--accent-cyan);
    letter-spacing: 0.1em;
  }

  .bar-leds {
    display: flex;
    gap: var(--space-xs);
  }

  .led {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--accent-cyan);
    animation: led-pulse 2s ease-in-out infinite;
  }

  @keyframes led-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .header-content {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .section-title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--lab-text-primary);
  }

  .view-all {
    display: flex;
    align-items: center;
    gap: 4px;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--accent-cyan);
    text-decoration: none;
    border: 1px solid var(--panel-border);
    border-radius: var(--radius-sm);
    padding: 2px 6px;
    background: var(--lab-bg-dark);
    transition: all 0.2s ease;
  }

  .view-all:hover {
    background: var(--lab-bg-elevated);
    border-color: var(--accent-cyan);
  }

  .posts-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }
</style>