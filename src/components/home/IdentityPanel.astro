---

import githubIcon from './src/icons/github.svg?raw';
import scholarIcon from './src/icons/scholar.svg?raw';
import linkedinIcon from './src/icons/linkedin.svg?raw';
import ieeeIcon from './src/icons/ieee.svg?raw';
import orcidIcon from './src/icons/orcid.svg?raw';
import arxivIcon from './src/icons/arxiv.svg?raw';
import emailIcon from './src/icons/email.svg?raw';
import cvIcon from './src/icons/cv.svg?raw';

type Cta = {
  href: string;
  label: string;
  icon?: string;
  variant?: 'primary' | 'secondary';
  external?: boolean;
};

type Stat = {
  label: string;
  value: string;
  led?: boolean;
};

type QuickFact = {
  label: string;
  value: string;
  icon?: string;
};

type Metric = {
  label: string;
  value: string;
  highlight?: boolean;
};

type SocialLink = {
  label: string;
  href: string;
  brand: string;
};

interface Props {
  class?: string;

  panelLabel?: string;
  moduleId?: string;
  ledPulse?: boolean;

  chipIcon?: string;
  chipIconSize?: number;
  chipLabel?: string;
  chipSub?: string;

  // old props kept for compatibility
  title?: string;
  focus?: string;
  tagline?: string;
  primaryCta?: Cta | null;
  secondaryCta?: Cta | null;
  stats?: Stat[];

  // new props
  name?: string;
  focusItems?: string[];
  quickFacts?: QuickFact[];
  nowItems?: string[];
  actions?: Cta[];
  socialLinks?: SocialLink[];
  metrics?: Metric[];
  experienceStartYear?: number;

  footerLabel?: string;
  portCount?: number;
  activePortIndex?: number;

  screwCount?: number;
  brassScrews?: boolean;
}

const {
  class: className = '',

  panelLabel = 'IDENTITY',
  moduleId = 'ID: JLMT-001',
  ledPulse = true,

  chipIcon = 'chip',
  chipIconSize = 20,
  chipLabel = 'JLMT',
  chipSub = 'LAB',

  name = 'Jorge L. Mayorga',
  title = 'Software Engineer \n Control & Robotics Researcher',
  focus = 'Robotics · Distributed Systems · FPGA',
  tagline = 'Building real-time systems from algorithms and embedded control to software products and research tooling.',

  primaryCta = null,
  secondaryCta = null,
  stats = [],

  focusItems = [],
  quickFacts = [],
  nowItems = [],
  actions = [],
  socialLinks = [],
  metrics = [],
  experienceStartYear = 2018,

  footerLabel = 'I/O',

  portCount = 4,
  activePortIndex = 1,

  screwCount = 2,
  brassScrews = true,
} = Astro.props as Props;

const currentYear = new Date().getFullYear();
const yearsOfExperience = Math.max(0, currentYear - experienceStartYear);

const normalizedScrewCount = Math.max(0, screwCount);
const normalizedPortCount = Math.max(0, portCount);
const normalizedActivePortIndex = Math.min(
  Math.max(0, activePortIndex),
  Math.max(0, normalizedPortCount - 1)
);

const extraScrews = Array.from({ length: Math.max(0, normalizedScrewCount - 2) });
const ports = Array.from({ length: normalizedPortCount }, (_, i) => i);

const isExternalUrl = (href?: string) =>
  typeof href === 'string' && /^(https?:)?\/\//.test(href);

const resolvedFocusItems =
  focusItems.length > 0
    ? focusItems
    : focus
        .split('·')
        .map((item) => item.trim())
        .filter(Boolean);

const resolvedQuickFacts =
  quickFacts.length > 0
    ? quickFacts
    : [
        { label: 'Based', value: 'Bogotá, Colombia', icon: 'location' },
        { label: 'Open To', value: 'Collaboration', icon: 'collab' },
        { label: 'Current', value: 'MSc Robotics', icon: 'current' },
        { label: 'Mode', value: 'Software + research', icon: 'mode' },
      ];



const resolvedActions: Cta[] =
  actions.length > 0
    ? [...actions]
    : [
        {
          href: '/cv',
          label: 'View CV',
          icon: 'cv',
          variant: 'primary',
        },
        {
          href: '/projects',
          label: 'Projects',
          icon: 'projects',
          variant: 'secondary',
        },
        {
          href: '/papers',
          label: 'Scholar',
          icon: 'scholar',
          variant: 'secondary',
        },
        {
          href: '/contact',
          label: 'Contact',
          icon: 'contact',
          variant: 'secondary',
        },
      ];

if (primaryCta) {
  resolvedActions.unshift({
    ...primaryCta,
    variant: primaryCta.variant ?? 'primary',
  });
}

if (secondaryCta) {
  resolvedActions.push({
    ...secondaryCta,
    variant: secondaryCta.variant ?? 'secondary',
  });
}

const resolvedSocialLinks =
  socialLinks.length > 0
    ? socialLinks
    : [
        {
          label: 'GitHub',
          href: 'https://github.com/jlmayorgaco',
          brand: 'github',
        },
        {
          label: 'Google Scholar',
          href: '/papers',
          brand: 'scholar',
        },
        {
          label: 'LinkedIn',
          href: '/contact',
          brand: 'linkedin',
        },
      ];

const resolvedMetrics =
  metrics.length > 0
    ? metrics
    : stats.length > 0
      ? stats.map((stat) => ({
          label: stat.label,
          value: stat.value,
          highlight: false,
        }))
      : [
          { label: 'Tech Stack', value: 'Angular | TS | Python | MATLAB | FPGA' },
          {
            label: 'Years of Experience',
            value: `+${yearsOfExperience}`,
            highlight: true,
          },
        ];

const factIconSvgs: Record<string, string> = {
  location: `
    <svg viewBox="0 0 24 24" aria-hidden="true" fill="none">
      <path d="M12 21s7-5.9 7-11a7 7 0 1 0-14 0c0 5.1 7 11 7 11Z" stroke="currentColor" stroke-width="1.8"/>
      <circle cx="12" cy="10" r="2.6" fill="currentColor"/>
    </svg>
  `,
  collab: `
    <svg viewBox="0 0 24 24" aria-hidden="true" fill="none">
      <path d="M8.5 12.5 11 15l2-2 2.5 2.5 4-4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M8 8.5 5.5 6 1.5 10l4 4 2.5-2.5M16 8.5 18.5 6l4 4-4 4-2.5-2.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  `,
  current: `
    <svg viewBox="0 0 24 24" aria-hidden="true" fill="none">
      <path d="M2 8.5 12 3l10 5.5L12 14 2 8.5Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
      <path d="M6 11.2V16m12-4.8V16M4.5 13.5c2 1.4 4.7 2.2 7.5 2.2s5.5-.8 7.5-2.2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
    </svg>
  `,
  mode: `
    <svg viewBox="0 0 24 24" aria-hidden="true" fill="none">
      <path d="M4 19h16M6 16V9m6 7V5m6 11v-4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
      <path d="m5 10 4-4 3 3 6-5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  `,
};

const actionIconSvgs: Record<string, string> = {
  cv: `
    <svg viewBox="0 0 24 24" aria-hidden="true" fill="none">
      <path d="M7 3h7l5 5v13H7z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
      <path d="M14 3v5h5M10 13h6M10 17h6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
    </svg>
  `,
  projects: `
    <svg viewBox="0 0 24 24" aria-hidden="true" fill="none">
      <path d="M3 7h6l2 2h10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
    </svg>
  `,
  scholar: `
    <svg viewBox="0 0 24 24" aria-hidden="true" fill="none">
      <path d="M12 3 2 8l10 5 10-5-10-5Z" fill="currentColor" opacity=".92"/>
      <path d="M6 10.5v4.2c0 1.7 3 3.3 6 3.3s6-1.6 6-3.3v-4.2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  `,
  contact: `
    <svg viewBox="0 0 24 24" aria-hidden="true" fill="none">
      <rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.8"/>
      <path d="m4 7 8 6 8-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  `,
  mail: `
    <svg viewBox="0 0 24 24" aria-hidden="true" fill="none">
      <rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.8"/>
      <path d="m4 7 8 6 8-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  `,
};

type SocialBrand =
  | 'github'
  | 'scholar'
  | 'linkedin'
  | 'ieee'
  | 'orcid'
  | 'arxiv'
  | 'email'
  | 'cv';

const socialIconSvgs: Record<SocialBrand, string> = {
  github: githubIcon,
  scholar: scholarIcon,
  linkedin: linkedinIcon,
  ieee: ieeeIcon,
  orcid: orcidIcon,
  arxiv: arxivIcon,
  email: emailIcon,
  cv: cvIcon,
};

const getFactIcon = (icon?: string) => (icon ? factIconSvgs[icon] ?? '' : '');
const getActionIcon = (icon?: string) => (icon ? actionIconSvgs[icon] ?? '' : '');
const getSocialIcon = (brand?: string) =>
  brand && brand in socialIconSvgs
    ? socialIconSvgs[brand as SocialBrand]
    : socialIconSvgs.github;
---

<div class:list={['panel', 'identity-panel', className]}>
  <div class="panel-header">
    <div class="header-left">
      <span class="label-tag">{panelLabel}</span>
      <span class="module-id">{moduleId}</span>
    </div>

    <div class="panel-leds">
      <span class:list={['led', 'led-green', ledPulse && 'led-pulse']}></span>
    </div>


  </div>

  <div class="panel-content identity-content">


    <div class="identity-info">
      <h1 class="identity-name">{name}</h1>
      <p class="identity-title">{title}</p>
      <p class="identity-tagline">{tagline}</p>
    </div>


    {resolvedFocusItems.length > 0 && (
      <div class="identity-focus-list">
        {resolvedFocusItems.map((item) => <span class="identity-pill">{item}</span>)}
      </div>
    )}

    {resolvedQuickFacts.length > 0 && (
      <div class="identity-facts">
        {resolvedQuickFacts.map((fact) => (
          <div class="fact-item">
            <div class="fact-head">
              {getFactIcon(fact.icon) && (
                <span class="fact-icon" set:html={getFactIcon(fact.icon)}></span>
              )}
              <span class="fact-label">{fact.label}</span>
            </div>

            <div class="fact-value-row">
              <span class="fact-value">{fact.value}</span>
            </div>
          </div>
        ))}
      </div>
    )}



    <slot name="extra" />

       {resolvedSocialLinks.length > 0 && (
      <div class="identity-social">
        {resolvedSocialLinks.map((item) => {
          const openExternally = isExternalUrl(item.href);

          return (
            <a
              href={item.href}
              class:list={['social-link', `social-link--${item.brand}`]}
              target={openExternally ? '_blank' : undefined}
              rel={openExternally ? 'noreferrer noopener' : undefined}
              aria-label={item.label}
            >
              <span
                class="social-link__icon"
                aria-hidden="true"
                set:html={getSocialIcon(item.brand)}
              ></span>
            </a>
          );
        })}
      </div>
    )}
    
    {resolvedActions.length > 0 && (
      <div class="identity-ctas">
        {resolvedActions.map((action) => {
          const openExternally = action.external ?? isExternalUrl(action.href);

          return (
            <a
              href={action.href}
              class:list={[
                'identity-cta',
                action.variant === 'primary'
                  ? 'identity-cta--primary'
                  : 'identity-cta--secondary',
              ]}
              target={openExternally ? '_blank' : undefined}
              rel={openExternally ? 'noreferrer noopener' : undefined}
              aria-label={action.label}
            >
              {getActionIcon(action.icon) && (
                <span
                  class="identity-cta__icon"
                  aria-hidden="true"
                  set:html={getActionIcon(action.icon)}
                ></span>
              )}
              <span>{action.label}</span>
            </a>
          );
        })}
      </div>
    )}

 

    <div class="identity-metrics">
      <div class="metric-item" style="border-bottom: none; margin-bottom: 4px;">
        <span class="metric-label">Years of Experience</span>
        <span class="metric-value metric-value--highlight">
          +{yearsOfExperience}
        </span>
      </div>
      
      <div class="tech-stack-badges" style="display: flex; flex-wrap: wrap; gap: 8px; margin-top: 12px; padding-top: 16px; border-top: 1px solid rgba(var(--color-primary-rgb, 0, 255, 170), 0.15);">
        <img src="https://img.shields.io/badge/Angular-DD0031?style=flat&logo=angular&logoColor=white" height="22" alt="Angular" />
        <img src="https://img.shields.io/badge/TypeScript-007ACC?style=flat&logo=typescript&logoColor=white" height="22" alt="TypeScript" />
        <img src="https://img.shields.io/badge/Python-3776AB?style=flat&logo=python&logoColor=white" height="22" alt="Python" />
        <img src="https://img.shields.io/badge/C%2B%2B-00599C?style=flat&logo=c%2B%2B&logoColor=white" height="22" alt="C++" />
        <img src="https://img.shields.io/badge/ROS-22314E?style=flat&logo=ros&logoColor=white" height="22" alt="ROS" />
        <img src="https://img.shields.io/badge/MATLAB-e16737?style=flat&logo=mathworks&logoColor=white" height="22" alt="MATLAB" />
        <img src="https://img.shields.io/badge/FPGA-4B5563?style=flat&logo=intel&logoColor=white" height="22" alt="FPGA" />
      </div>
    </div>
  </div>

  <div class="panel-footer">
    <div class="port-row" aria-hidden="true">
      {ports.map((index) => (
        <span class:list={['port', index === normalizedActivePortIndex && 'port-active']}></span>
      ))}
    </div>

    <span class="port-label">{footerLabel}</span>
  </div>
</div>