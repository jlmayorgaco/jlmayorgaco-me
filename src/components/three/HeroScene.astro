---
interface Props {
  variant?: 'full' | 'compact';
}

const { variant = 'full' } = Astro.props;
---

<div class:list={['hero-canvas', `canvas-${variant}`} ref:any={undefined}>
  <canvas id="hero-canvas"></canvas>
  
  <div class="canvas-overlay">
    <div class="corner corner-tl">
      <svg viewBox="0 0 40 40" fill="none">
        <path d="M0 10 L0 0 L10 0" stroke="currentColor" stroke-width="2"/>
        <circle cx="5" cy="5" r="2" fill="currentColor"/>
      </svg>
    </div>
    <div class="corner corner-tr">
      <svg viewBox="0 0 40 40" fill="none">
        <path d="M40 10 L40 0 L30 0" stroke="currentColor" stroke-width="2"/>
        <circle cx="35" cy="5" r="2" fill="currentColor"/>
      </svg>
    </div>
    <div class="corner corner-bl">
      <svg viewBox="0 0 40 40" fill="none">
        <path d="M0 30 L0 40 L10 40" stroke="currentColor" stroke-width="2"/>
        <circle cx="5" cy="35" r="2" fill="currentColor"/>
      </svg>
    </div>
    <div class="corner corner-br">
      <svg viewBox="0 0 40 40" fill="none">
        <path d="M40 30 L40 40 L30 40" stroke="currentColor" stroke-width="2"/>
        <circle cx="35" cy="35" r="2" fill="currentColor"/>
      </svg>
    </div>
  </div>
  
  <div class="canvas-info">
    <span class="info-label">SYS.DISPLAY</span>
    <span class="info-status">
      <span class="led led-green"></span>
      ACTIVE
    </span>
  </div>
</div>

<style>
  .hero-canvas {
    position: relative;
    width: 100%;
    height: 400px;
    background: linear-gradient(180deg, var(--screen-bg) 0%, #0a0f14 100%);
    border: 2px solid var(--screen-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .canvas-full {
    height: 500px;
  }

  .canvas-compact {
    height: 250px;
  }

  #hero-canvas {
    width: 100%;
    height: 100%;
    display: block;
  }

  .canvas-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    pointer-events: none;
  }

  .corner {
    position: absolute;
    width: 40px;
    height: 40px;
    color: var(--accent-cyan);
    opacity: 0.6;
  }

  .corner-tl { top: 0; left: 0; }
  .corner-tr { top: 0; right: 0; }
  .corner-bl { bottom: 0; left: 0; }
  .corner-br { bottom: 0; right: 0; }

  .canvas-info {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-sm) var(--space-md);
    background: var(--lab-bg-dark);
    border-top: 1px solid var(--panel-border);
  }

  .info-label {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    color: var(--lab-text-muted);
    letter-spacing: 0.1em;
  }

  .info-status {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    color: var(--led-green);
    letter-spacing: 0.05em;
  }

  .led {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--led-green);
    box-shadow: 0 0 4px var(--led-green);
  }

  @media (max-width: 768px) {
    .hero-canvas {
      height: 300px;
    }
  }
</style>

<script>
  import * as THREE from 'three';

  const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement;
  
  if (canvas) {
    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(75, canvas.clientWidth / canvas.clientHeight, 0.1, 1000);
    const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
    
    renderer.setSize(canvas.clientWidth, canvas.clientHeight);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    
    // Colors
    const cyan = new THREE.Color(0x06b6d4);
    const darkCyan = new THREE.Color(0x0e7490);
    const copper = new THREE.Color(0x9a7a5a);
    
    // Create nodes
    const nodeGeometry = new THREE.SphereGeometry(0.15, 32, 32);
    const nodeMaterial = new THREE.MeshBasicMaterial({ color: cyan });
    
    const nodes: THREE.Mesh[] = [];
    const nodePositions = [
      { x: -2, y: 1, z: 0 },
      { x: 2, y: 1, z: 0 },
      { x: 0, y: 0, z: 0 },
      { x: -1.5, y: -1, z: 0 },
      { x: 1.5, y: -1, z: 0 },
      { x: 0, y: 1.5, z: -1 },
    ];
    
    nodePositions.forEach(pos => {
      const node = new THREE.Mesh(nodeGeometry, nodeMaterial.clone());
      node.position.set(pos.x, pos.y, pos.z);
      nodes.push(node);
      scene.add(node);
    });
    
    // Create connections
    const connections = [
      [0, 2], [1, 2], [2, 3], [2, 4], [3, 4], [0, 5], [1, 5], [5, 2]
    ];
    
    const lineMaterial = new THREE.LineBasicMaterial({ 
      color: cyan, 
      transparent: true, 
      opacity: 0.4 
    });
    
    connections.forEach(([a, b]) => {
      const geometry = new THREE.BufferGeometry().setFromPoints([
        nodes[a].position,
        nodes[b].position
      ]);
      const line = new THREE.Line(geometry, lineMaterial);
      scene.add(line);
    });
    
    // Add floating particles
    const particleCount = 100;
    const particleGeometry = new THREE.BufferGeometry();
    const positions = new Float32Array(particleCount * 3);
    
    for (let i = 0; i < particleCount * 3; i += 3) {
      positions[i] = (Math.random() - 0.5) * 8;
      positions[i + 1] = (Math.random() - 0.5) * 6;
      positions[i + 2] = (Math.random() - 0.5) * 4;
    }
    
    particleGeometry.setAttribute('position', new THREE.BufferAttribute(positions, 3));
    const particleMaterial = new THREE.PointsMaterial({
      color: cyan,
      size: 0.02,
      transparent: true,
      opacity: 0.6
    });
    const particles = new THREE.Points(particleGeometry, particleMaterial);
    scene.add(particles);
    
    // Camera position
    camera.position.z = 4;
    
    // Mouse interaction
    let mouseX = 0;
    let mouseY = 0;
    
    document.addEventListener('mousemove', (event) => {
      mouseX = (event.clientX / window.innerWidth) * 2 - 1;
      mouseY = -(event.clientY / window.innerHeight) * 2 + 1;
    });
    
    // Animation
    let time = 0;
    
    function animate() {
      requestAnimationFrame(animate);
      time += 0.01;
      
      // Rotate nodes slightly
      nodes.forEach((node, i) => {
        node.position.y += Math.sin(time + i) * 0.001;
      });
      
      // Gentle camera movement based on mouse
      camera.position.x += (mouseX * 0.5 - camera.position.x) * 0.02;
      camera.position.y += (mouseY * 0.3 - camera.position.y) * 0.02;
      camera.lookAt(0, 0, 0);
      
      // Rotate particles
      particles.rotation.y = time * 0.05;
      
      renderer.render(scene, camera);
    }
    
    animate();
    
    // Handle resize
    window.addEventListener('resize', () => {
      const width = canvas.clientWidth;
      const height = canvas.clientHeight;
      camera.aspect = width / height;
      camera.updateProjectionMatrix();
      renderer.setSize(width, height);
    });
  }
</script>