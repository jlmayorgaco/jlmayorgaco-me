---
import type { CollectionEntry } from 'astro:content';
import Icon from '../ui/Icon.astro';

interface Props {
  item: CollectionEntry<'portfolio'>;
  variant?: 'default' | 'featured' | 'compact';
}

const { item, variant = 'default' } = Astro.props;
const { data } = item;
---

<a href={`/portfolio/${item.id}`} class:list={['portfolio-card', `card-${variant}`]}>
  <div class="card-header">
    <div class="header-label">{data.category}</div>
    <span class="card-year">{data.year}</span>
  </div>
  
  <div class="card-content">
    <h3 class="card-title">{data.title}</h3>
    <p class="card-description">{data.description}</p>
    
    {data.tags && variant !== 'compact' && (
      <div class="card-tags">
        {data.tags.slice(0, 4).map((tag) => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    )}
  </div>
  
  <div class="card-footer">
    <div class="status-indicator">
      <span class={`status-dot ${data.status}`}></span>
      <span class="status-label">{data.status}</span>
    </div>
    <Icon name="arrow_right" size={12} />
  </div>
</a>

<style>
  .portfolio-card {
    display: flex;
    flex-direction: column;
    background: var(--lab-bg-panel);
    border: 1px solid var(--panel-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .portfolio-card:hover {
    border-color: var(--accent-cyan);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px -4px rgba(0, 0, 0, 0.4);
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-sm) var(--space-md);
    background: var(--lab-bg-dark);
    border-bottom: 1px solid var(--panel-border);
  }

  .header-label {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    color: var(--accent-cyan);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .card-year {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--lab-text-muted);
  }

  .card-content {
    padding: var(--space-md);
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .card-title {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--lab-text-primary);
    margin-bottom: var(--space-sm);
    line-height: 1.3;
  }

  .card-description {
    font-size: 0.875rem;
    color: var(--lab-text-secondary);
    line-height: 1.5;
    margin-bottom: var(--space-md);
    flex: 1;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    padding: 2px 6px;
    background: var(--lab-bg-dark);
    border: 1px solid var(--panel-border);
    border-radius: var(--radius-sm);
    color: var(--lab-text-muted);
  }

  .card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-sm) var(--space-md);
    border-top: 1px solid var(--panel-border);
  }

  .status-indicator {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
  }

  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
  }

  .status-dot.published {
    background: var(--led-green);
    box-shadow: 0 0 4px var(--led-green);
  }

  .status-dot.wip {
    background: var(--led-amber);
    box-shadow: 0 0 4px var(--led-amber);
  }

  .status-dot.archived {
    background: var(--lab-text-muted);
  }

  .status-label {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    color: var(--lab-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .card-footer Icon {
    color: var(--lab-text-muted);
    transition: transform 0.2s ease;
  }

  .portfolio-card:hover .card-footer Icon {
    transform: translateX(4px);
    color: var(--accent-cyan);
  }

  .card-compact {
    flex-direction: row;
    align-items: center;
  }

  .card-compact .card-content {
    padding: var(--space-sm);
  }

  .card-compact .card-title {
    font-size: 0.9375rem;
  }

  .card-compact .card-description {
    display: none;
  }
</style>