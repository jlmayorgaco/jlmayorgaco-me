---
import type { CollectionEntry } from 'astro:content';
import PortfolioCard from './PortfolioCard.astro';
import Icon from '../ui/Icon.astro';

interface Props {
  projects: CollectionEntry<'projects'>[];
  variant?: 'default' | 'featured';
}

const { projects, variant = 'default' } = Astro.props;
---

<div class:list={['project-grid', `grid-${variant}`]}>
  <div class="grid-header-bar">
    <div class="bar-screws">
      <Icon name="screw" size={10} />
      <Icon name="screw" size={10} />
    </div>
    <div class="bar-label">{variant === 'featured' ? 'FEATURED_PROJECTS' : 'PROJECT_NODES'}</div>
    <div class="bar-leds">
      <span class="led"></span>
    </div>
  </div>
  {projects.map((project) => (
    <PortfolioCard {project} variant={variant === 'featured' ? 'featured' : 'default'} />
  ))}
  <div class="grid-footer-stripe"></div>
</div>

<style>
  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--space-lg);
  }

  .grid-featured {
    grid-template-columns: repeat(2, 1fr);
  }

  .grid-header-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-sm) var(--space-md);
    background: var(--lab-bg-dark);
    border-bottom: 1px solid var(--panel-border);
    margin-bottom: calc(var(--space-lg) * -1);
  }

  .bar-screws {
    display: flex;
    gap: var(--space-md);
    color: var(--lab-text-muted);
  }

  .bar-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--accent-cyan);
    letter-spacing: 0.1em;
  }

  .bar-leds {
    display: flex;
    gap: var(--space-xs);
  }

  .led {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--accent-cyan);
    animation: led-pulse 2s ease-in-out infinite;
  }

  @keyframes led-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .grid-footer-stripe {
    width: 100%;
    height: 3px;
    background: repeating-linear-gradient(
      90deg,
      var(--panel-border) 0px,
      var(--panel-border) 4px,
      transparent 4px,
      transparent 8px
    );
    margin-top: calc(var(--space-lg) * -1);
  }

  @media (max-width: 768px) {
    .grid-featured {
      grid-template-columns: 1fr;
    }
  }
</style>