---
import type { CollectionEntry } from 'astro:content';
import PaperCard from './PaperCard.astro';

interface Props {
  papers: CollectionEntry<'papers'>[];
}

const { papers } = Astro.props;
---

<div class="paper-list">
  {papers.map((paper) => (
    <PaperCard paper={paper} />
  ))}
</div>

<style>
  .paper-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }
</style>