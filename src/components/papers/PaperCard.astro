---
import type { CollectionEntry } from 'astro:content';
import Badge from '../ui/Badge.astro';
import Icon from '../ui/Icon.astro';

interface Props {
  paper: CollectionEntry<'papers'>;
}

const { paper } = Astro.props;
const { data } = paper;
---

<div class="paper-card">
  <div class="card-header-bar">
    <div class="bar-screws">
      <Icon name="screw" size={10} />
      <Icon name="screw" size={10} />
    </div>
    <div class="bar-label">PAPER_LOG_{data.year}</div>
    <div class="bar-leds">
      <span class="led"></span>
    </div>
  </div>
  
  <div class="paper-content">
    <div class="paper-header">
      <span class="paper-year">{data.year}</span>
      <span class="paper-venue">{data.venue}</span>
    </div>
    
    <h3 class="paper-title">{data.title}</h3>
    
    <p class="paper-authors">
      {data.authors.join(', ')}
    </p>
    
    <p class="paper-abstract">{data.abstract}</p>
    
    <div class="paper-links">
      {data.pdf && (
        <a href={data.pdf} target="_blank" rel="noopener noreferrer" class="paper-link">
          <Icon name="file" size={12} />
          PDF
        </a>
      )}
      {data.slides && (
        <a href={data.slides} target="_blank" rel="noopener noreferrer" class="paper-link">
          <Icon name="presentation" size={12} />
          Slides
        </a>
      )}
      {data.doi && (
        <a href={data.doi} target="_blank" rel="noopener noreferrer" class="paper-link">
          <Icon name="link" size={12} />
          DOI
        </a>
      )}
    </div>
  </div>
</div>

<style>
  .paper-card {
    background: var(--lab-bg-panel);
    border: 1px solid var(--panel-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .card-header-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-xs) var(--space-sm);
    background: var(--lab-bg-dark);
    border-bottom: 1px solid var(--panel-border);
  }

  .bar-screws {
    display: flex;
    gap: var(--space-md);
    color: var(--lab-text-muted);
    opacity: 0.6;
  }

  .bar-label {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    color: var(--lab-text-muted);
    letter-spacing: 0.1em;
  }

  .bar-leds {
    display: flex;
    gap: var(--space-xs);
  }

  .led {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--accent-cyan);
    animation: led-pulse 2s ease-in-out infinite;
  }

  @keyframes led-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .paper-content {
    padding: var(--space-lg);
  }

  .paper-header {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-sm);
  }

  .paper-year {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--accent-cyan);
  }

  .paper-venue {
    font-size: 0.875rem;
    color: var(--lab-text-muted);
  }

  .paper-title {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--lab-text-primary);
    margin-bottom: var(--space-sm);
    line-height: 1.3;
  }

  .paper-authors {
    font-size: 0.875rem;
    color: var(--lab-text-secondary);
    margin-bottom: var(--space-md);
  }

  .paper-abstract {
    font-size: 0.875rem;
    color: var(--lab-text-muted);
    line-height: 1.5;
    margin-bottom: var(--space-md);
  }

  .paper-links {
    display: flex;
    gap: var(--space-sm);
  }

  .paper-link {
    display: flex;
    align-items: center;
    gap: 4px;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--accent-cyan);
    text-decoration: none;
    padding: var(--space-xs) var(--space-sm);
    background: var(--lab-bg-dark);
    border: 1px solid var(--panel-border);
    border-radius: var(--radius-sm);
    transition: all 0.2s ease;
  }

  .paper-link:hover {
    background: var(--lab-bg-elevated);
    border-color: var(--accent-cyan);
  }
</style>