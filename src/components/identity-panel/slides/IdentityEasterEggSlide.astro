---
import type { IdentityEasterEggSlideData } from '../IdentityPanel.types';

interface Props extends IdentityEasterEggSlideData {}

const {
  title = 'Hidden mode',
  lines = [],
  action,
} = Astro.props as Props;

const isLinkAction = Boolean(action?.href);
const hasAction = Boolean(action?.label);
---

<div class="identity-slide identity-slide--easter-egg">
  <div class="identity-easter-egg" aria-label={title}>
    <div class="identity-easter-egg__panel">
      <div class="identity-easter-egg__header">
        <span class="identity-easter-egg__dot"></span>
        <span class="identity-easter-egg__title">{title}</span>
      </div>

      <div class="identity-easter-egg__body" role="log" aria-live="polite">
        {lines.length > 0 ? (
          <ul class="identity-easter-egg__lines" role="list">
            {lines.map((line, index) => (
              <li class="identity-easter-egg__line">
                <span class="identity-easter-egg__prompt" aria-hidden="true">
                  {index === 0 ? '>' : '·'}
                </span>
                <span class="identity-easter-egg__text">{line}</span>
              </li>
            ))}
          </ul>
        ) : (
          <p class="identity-easter-egg__empty">No hidden signals detected.</p>
        )}
      </div>

      {hasAction && (
        <div class="identity-easter-egg__footer">
          {isLinkAction ? (
            <a
              href={action?.href}
              class="identity-easter-egg__action"
              data-easter-egg-action={action?.action}
            >
              {action?.label}
            </a>
          ) : (
            <button
              type="button"
              class="identity-easter-egg__action"
              data-easter-egg-action={action?.action}
            >
              {action?.label}
            </button>
          )}
        </div>
      )}
    </div>
  </div>
</div>