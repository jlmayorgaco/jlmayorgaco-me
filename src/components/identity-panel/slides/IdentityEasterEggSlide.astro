---
import type { IdentityEasterEggSlideData } from '../IdentityPanel.types';

interface Props extends IdentityEasterEggSlideData {}

const {
  title = 'Hidden mode',
  lines = [],
  action,
} = Astro.props as Props;

const isLinkAction = Boolean(action?.href);
const hasAction = Boolean(action?.label);
---

<div class="identity-slide identity-slide--easter-egg">
  <div class="identity-easter-egg" aria-label={title}>
    <div class="identity-easter-egg__panel" data-egg-game>
      <div class="identity-easter-egg__header">
        <span class="identity-easter-egg__dot"></span>
        <span class="identity-easter-egg__title">{title}</span>
        <span class="identity-easter-egg__status" data-egg-status>STANDBY</span>
      </div>

      <div class="identity-easter-egg__body" role="log" aria-live="polite">
        <div class="identity-easter-egg__scope" aria-hidden="true">
          <div class="identity-easter-egg__scope-grid"></div>
          <div class="identity-easter-egg__target-window"></div>
          <div class="identity-easter-egg__sweep" data-egg-sweep></div>
          <svg
            class="identity-easter-egg__wave"
            viewBox="0 0 320 88"
            preserveAspectRatio="none"
            focusable="false"
          >
            <path
              class="identity-easter-egg__wave-path identity-easter-egg__wave-path--ghost"
              d="M0 49 C18 18 34 18 52 49 S86 80 104 49 S138 18 156 49 S190 80 208 49 S242 18 260 49 S294 80 320 49"
            />
            <path
              class="identity-easter-egg__wave-path"
              d="M0 49 C18 18 34 18 52 49 S86 80 104 49 S138 18 156 49 S190 80 208 49 S242 18 260 49 S294 80 320 49"
            />
          </svg>
          <div class="identity-easter-egg__nodes">
            <span style="--node-x: 18%; --node-y: 68%;"></span>
            <span style="--node-x: 44%; --node-y: 28%;"></span>
            <span style="--node-x: 72%; --node-y: 58%;"></span>
          </div>
        </div>

        <div class="identity-easter-egg__readout">
          <span>SIGNAL LOCK</span>
          <strong data-egg-score>0/3</strong>
        </div>

        {lines.length > 0 ? (
          <ul class="identity-easter-egg__lines" role="list">
            {lines.map((line, index) => (
              <li class="identity-easter-egg__line">
                <span class="identity-easter-egg__prompt" aria-hidden="true">
                  {index === 0 ? '>' : '*'}
                </span>
                <span class="identity-easter-egg__text">{line}</span>
              </li>
            ))}
          </ul>
        ) : (
          <p class="identity-easter-egg__empty">No hidden signals detected.</p>
        )}
      </div>

      {hasAction && (
        <div class="identity-easter-egg__footer">
          {isLinkAction ? (
            <a
              href={action?.href}
              class="identity-easter-egg__action"
              data-easter-egg-action={action?.action}
              data-egg-action
            >
              {action?.label}
            </a>
          ) : (
            <button
              type="button"
              class="identity-easter-egg__action"
              data-easter-egg-action={action?.action}
              data-egg-action
            >
              {action?.label}
            </button>
          )}
        </div>
      )}
    </div>
  </div>
</div>
