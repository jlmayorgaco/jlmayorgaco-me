---
interface Props {
  panelLabel?: string;
  ledPulse?: boolean;

  statusLabel?: string;
}

const {
  panelLabel = 'IDENTITY',
  ledPulse = true,

  statusLabel = 'Panel status',
} = Astro.props as Props;
---

<div class="panel-header identity-panel__header">
  <div class="identity-panel__header-left">
    <span class="label-tag">{panelLabel}</span>
  </div>

  <div class="panel-leds identity-panel__leds" aria-label={statusLabel}>
    <span class:list={['led', 'led-green', ledPulse && 'led-pulse']}></span>
  </div>
</div>
